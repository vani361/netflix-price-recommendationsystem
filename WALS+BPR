           writer.write_table(table)\n","            total_rows += len(chunk)\n","\n","        if writer:\n","            writer.close()\n","\n","        elapsed = time.time() - start\n","        csv_size_mb = os.path.getsize(csv_path) / (1024 * 1024)\n","        pq_size_mb = os.path.getsize(parquet_path) / (1024 * 1024)\n","        compression_ratio = (1 - pq_size_mb / csv_size_mb) * 100\n","\n","        print(f\"  Processed {total_rows:,} rows in {elapsed:.1f}s.\")\n","        print(f\"  CSV Size: {csv_size_mb:.2f} MB | Parquet Size: {pq_size_mb:.2f} MB ({compression_ratio:.1f}% reduction!)\", flush=True)\n","\n","    except Exception as e:\n","        print(f\"  Error converting {csv_path}: {e}\", file=sys.stderr)\n","        if writer:\n","            writer.close()\n","        if os.path.exists(parquet_path):\n","            os.remove(parquet_path)\n","        return False\n","    return True\n","\n","def main():\n","    parser = argparse.ArgumentParser(description=\"Optimize Netflix dataset CSVs into memory-efficient Parquet format.\")\n","    default_dir = \"/content/drive/Shareddrives/netflixrecommendationsystem/dataset\" if os.path.exists(\"/content/drive/Shareddrives/netflixrecommendationsystem/dataset\") else \".\"\n","    parser.add_argument(\"--data-dir\", default=default_dir, help=\"Base directory for all input and output files (useful for Colab/Drive).\")\n","    args, unknown = parser.parse_known_args()\n","\n","    data_dir = args.data_dir\n","    def resolve_path(p):\n","        if os.path.isabs(p):\n","            return p\n","        return os.path.join(data_dir, p)\n","\n","    possible_ratings_files = [ \"/content/drive/Shareddrives/netflixrecommendationsystem/dataset/merged_netflix_data.csv\"]\n","    ratings_file = None\n","    for f in possible_ratings_files:\n","        path = resolve_path(f)\n","        if os.path.exists(path):\n","            ratings_file = f\n","            break\n","\n","    if not ratings_file:\n","        print(f\"Err