[0m\n","\u001b[?25hInstalling collected packages: numpy\n","  Attempting uninstall: numpy\n","    Found existing installation: numpy 2.4.6\n","    Uninstalling numpy-2.4.6:\n","      Successfully uninstalled numpy-2.4.6\n","\u001b[31mERROR: pip's dependency resolver does not currently take into account all the packages that are installed. This behaviour is the source of the following dependency conflicts.\n","google-colab 1.0.0 requires pandas==2.2.2, but you have pandas 3.0.3 which is incompatible.\n","gradio 5.50.0 requires pandas<3.0,>=1.0, but you have pandas 3.0.3 which is incompatible.\n","cudf-cu12 26.2.1 requires pandas<2.4.0,>=2.0, but you have pandas 3.0.3 which is incompatible.\n","dask-cudf-cu12 26.2.1 requires pandas<2.4.0,>=2.0, but you have pandas 3.0.3 which is incompatible.\u001b[0m\u001b[31m\n","\u001b[0mSuccessfully installed numpy-2.0.2\n"]},{"output_type":"display_data","data":{"application/vnd.colab-display-data+json":{"pip_warning":{"packages":["numpy"]},"id":"e9fc834db8544be29925f00268227815"}},"metadata":{}}]},{"cell_type":"code","source":["#!/usr/bin/env python3\n","\"\"\"\n","Stage 2: BPR — Bayesian Personalised Ranking Reranker (FAST, RAM-SAFE)\n","=======================================================================\n","Loads the WALS stage-1 model, uses it to generate per-user candidate sets,\n","then trains a dedicated BPR embedding model with a pairwise ranking loss.\n","\n","Speed changes vs original (RAM footprint unchanged or lower):\n","  - sample_negatives_mixed: parallel=True + prange (multi-core CPU sampling)\n","  - per-epoch flat positive/negative index pre-expansion (less Python overhead)\n","  - loss/bpr accumulated as GPU tensors -> .item() called once per epoch\n","    (removes ~600 host<->device syncs/epoch)\n","  - GradScaler for proper AMP scaling (fewer wasted steps)\n","  - larger BPR_BATCH (embeddings are tiny: ~20M params total, T4 has 16GB VRAM)\n","  - tqdm mininterval to cut overhead from per-batch refresh\n","\n","OOM-SAFE, HARDWARE ACCELERATED & FLAT RAM LOADER VERSION (12GB RAM SAFE)\n","\"\"\"\n","\n","import argparse, gc, os, pickle, time\n","import numpy as np\n","import pandas as pd\n","import torch\n","import torch.nn as nn\n","import torch.nn.functional as F\n","from tqdm.auto import tqdm\n","from scipy.sparse import csr_matrix\n","import numba as nb\n","\n","# Enable TF32 Hardware Acceleration for Ampere GPUs\n","torch.backends.cuda.matmul.allow_tf32 = True\n","torch.backends.cudnn.allow_tf32 = True\n","\n","# ── CONFIG ────────────────────────────────────────────────────────────────────\n","BPR_FACTORS      = 128       # embedding dim for BPR (increased to 128 to match/exceed WALS)\n","BPR_LR           = 5e-4      # stable learning rate\n","BPR_REG          = 5e-4      # stronger L2 regularisation to prevent overfitting\n","BPR_EPOCHS       = 50        # more epochs, controlled by early stopping\n","BPR_BATCH        = 524288    # batch size for GPU acceleration (increased to 524288 to compensate for NEG_SAMPLES=4)\n","NEG_SAMPLES      = 4         # negatives per positive per batch (reduced to 4 to speed up training)\n","N_CANDIDATES     = 1000      # WALS retrieval size for candidate pool (increased to 1000 to improve reranking ceiling)\n","RELEVANCE_THRESH = 3.5\n","TOP_K            = 10\n","MAX_EVAL_USERS   = 5_000\n","RANDOM_SEED      = 42\n","PATIENCE         = 3         # patience checks (each check is 3 epochs, so 9 epochs without improvement)\n","\n","CANDIDATE_DIRS = [\n","    \"/content/drive/Sharedrives/netflixrecommendationsystem/dataset\",\n","    \"/content/drive/Sharedrives/netflixrecommendationsystem/dataset\",\n","    \"/content/drive/Shareddrives/netflixrecommendationsystem/dataset\",\n","    \".\",\n","]\n","SAVE_DIR_CANDIDATES = [\n","    \"/content/drive/Shareddrives/netflixrecommendationsystem\",\n","    \"\",\n","]\n","\n","def find_data_dir():\n","    for d in CANDIDATE_DIRS:\n","        if os.path.exists(os.path.join(d, \"train.parquet\")):\n","            return d\n","    raise FileNotFoundError(\"train.parquet not found\")\n","\n","def find_save_dir():\n","    for d in SAVE_DIR_CANDIDATES:\n","        if d == \"\" or os.path.exists(d):\n","            return d\n","    return \"\"\n","\n","def find_wals(save_dir):\n","    for p in [os.path.join(save_dir, \"wals_stage1.pkl\"), \"wals_stage1.pkl\",\n","              os.path.join(save_dir, \"wals_best.pkl\"),   \"wals_best.pkl\",\n","              os.path.join(save_dir, \"wals_model.pkl\"),  \"wals_model.pkl\"]:\n","        if os.path.exists(p):\n","            return p\n","    raise FileNotFoundError(\"WALS model not found — run wals_stage1.py first\")\n","\n","# ── 1. DATA ───────────────────────────────────────────────────────────────────\n","def load_df(path):\n","    if path.endswith(\".parquet\"):\n","        import pyarrow.parquet as pq\n","        cols = pq.ParquetFile(path).schema.names\n","    else:\n","        cols = list(pd.read_csv(path, nrows=0).columns)\n","    col_map = {}\n","    for c in cols:\n","        cl = c.lower()\n","        if   cl in (\"customerid\",\"userid\",\"user_id\",\"customer_id\"): col_map[\"CustomerID\"] = c\n","        elif cl in (\"movieid\",\"itemid\",\"movie_id\",\"item_id\"):        col_map[\"MovieID\"]    = c\n","        elif cl in (\"rating\",\"ratings\"):                             col_map[\"Rating\"]     = c\n","    load = [col_map[k] for k in [\"CustomerID\",\"MovieID\",\"Rating\"] if k in col_map]\n","    df = (pd.read_parquet(path, columns=load) if path.endswith(\".parquet\")\n","          else pd.read_csv(path, usecols=load))\n","    df.rename(columns={v: k for k, v in col_map.items()}, inplace=True)\n","    df = df.loc[:, ~df.columns.duplicated()]\n","    df[\"CustomerID\"] = df[\"CustomerID\"].astype(\"int32\")\n","    df[\"MovieID\"]    = df[\"MovieID\"].astype(\"int32\")\n","    df[\"Rating\"]     = df[\"Rating\"].astype(\"float32\")\n","    return df\n","\n","# ── 2. NUMBA FAST SAMPLER (MIXED HARD/RANDOM) ──────────────────────────────────\n","@nb.njit(nogil=True, cache=True, parallel=True)\n","def sample_negatives_mixed(u_batch, neg_indptr, neg_indices, n_items, hard_ratio=0.5):\n","    \"\"\"\n","    Mix hard negatives (from WALS candidate pool) with uniform random negatives.\n","    Hard negatives teach discrimination; random negatives prevent mode collapse.\n","    \"\"\"\n","    n = len(u_batch)\n","    neg_batch = np.empty(n, dtype=np.int32)\n","    for i in nb.prange(n):\n","        u = u_batch[i]\n","        use_hard = (np.random.random() < hard_ratio)\n","        start = neg_indptr[u]\n","        end = neg_indptr[u+1]\n","        diff = end - start\n","        if use_hard and diff > 0:\n","            neg_batch[i] = neg_indices[start + np.random.randint(0, diff)]\n","        else:\n","            neg_batch[i] = np.random.randint(0, n_items)\n","    return neg_batch\n","\n","# ── 3. BPR MODEL ──────────────────────────────────────────────────────────────\n","class BPRModel(nn.Module):\n","    \"\"\"\n","    Standard MF with BPR loss. Optionally conditions on WALS dot-product\n","    score (scalar feature) via a learned scalar weight.\n","    \"\"\"\n","    def __init__(self, n_users, n_items, factors=BPR_FACTORS,\n","                 use_wals_features=False):\n","        super().__init__()\n","        self.use_wals_features = use_wals_features\n","        self.user_emb = nn.Embedding(n_users, factors)\n","        self.item_emb = nn.Embedding(n_items, factors)\n","        self.item_bias = nn.Embedding(n_items, 1)\n","\n","        # Residual scale: how much to trust BPR corrections vs WALS init\n","        # Start small so early training doesn't disrupt the warm start\n","        self.residual_scale = nn.Parameter(torch.tensor(0.1))\n","\n","        nn.init.normal_(self.user_emb.weight, std=0.01)   # small residual init\n","        nn.init.normal_(self.item_emb.weight, std=0.01)\n","        nn.init.zeros_(self.item_bias.weight)\n","        if use_wals_features:\n","            # unconstrained raw parameter for softplus mapping\n","            self.wals_w_raw = nn.Parameter(torch.tensor(0.5))\n","\n","    @property\n","    def wals_w(self):\n","        # softplus constraint guarantees non-negativity (wals_w > 0)\n","        return F.softplus(self.wals_w_raw)\n","\n","    def score(self, u, i):\n","        \"\"\"Scalar score for (user, item) pair.\"\"\"\n","        # BPR correction is scaled down initially, grows as residual_scale learns\n","        residual = (self.user_emb(u) * self.item_emb(i)).sum(-1) \\\n","                   + self.item_bias(i).squeeze(-1)\n","        return F.softplus(self.residual_scale) * residual\n","\n","    def forward(self, u, pos, neg,\n","                wals_pos=None, wals_neg=None):\n","        \"\"\"\n","        BPR loss: -mean log σ(score_pos - score_neg)\n","        Plus L2 regularisation on involved embeddings.\n","        \"\"\"\n","        s_pos = self.score(u, pos)\n","        s_neg = self.score(u, neg)\n","        diff  = s_pos - s_neg\n","\n","        if self.use_wals_features and wals_pos is not None:\n","            wals_pos_norm = (wals_pos - self.wals_mean) / self.wals_std\n","            wals_neg_norm = (wals_neg - self.wals_mean) / self.wals_std\n","            diff = diff + self.wals_w * (wals_pos_norm - wals_neg_norm)\n","\n","        bpr_loss = -F.logsigmoid(diff).mean()\n","\n","        # L2 reg only on embeddings in this batch (optimized to avoid redundant norm calls)\n","        reg_loss = ((self.user_emb(u) ** 2).sum(-1).mean()\n","                  + (self.item_emb(pos) ** 2).sum(-1).mean()\n","                  + (self.item_emb(neg) ** 2).sum(-1).mean()) * BPR_REG\n","\n","        if self.use_wals_features:\n","            reg_loss = reg_loss + (self.wals_w_raw ** 2) * BPR_REG\n","\n","        return bpr_loss + reg_loss, bpr_loss.detach()\n","\n","    @torch.no_grad()\n","    def score_candidates(self, u_idx: int, candidate_item_indices: np.ndarray,\n","                         device, wals_tensors=None) -> np.ndarray:\n","        \"\"\"Score a list of candidate items for a single user.\"\"\"\n","        idx_dtype = torch.long if device.type != \"mps\" else torch.int32\n","        u_t = torch.tensor([u_idx] * len(candidate_item_indices),\n","                           dtype=idx_dtype, device=device)\n","        i_t = torch.tensor(candidate_item_indices, dtype=idx_dtype, device=device)\n","\n","        bpr_score = self.score(u_t, i_t)\n","\n","        if self.use_wals_features and wals_tensors is not None:\n","            wals_uf, wals_if, wals_ub, wals_ib, wals_gm = wals_tensors\n","\n","            u_f = wals_uf[u_idx]\n","            i_f = wals_if[i_t]\n","            u_b = wals_ub[u_idx]\n","            i_b = wals_ib[i_t]\n","\n","            wals_score = wals_gm + u_b + i_b + (u_f * i_f).sum(-1)\n","            wals_score_norm = (wals_score - self.wals_mean) / self.wals_std\n","            bpr_score = bpr_score + self.wals_w * wals_score_norm\n","\n","        return bpr_score.cpu().numpy()\n","\n","def init_from_wals(bpr_model: BPRModel, wals: dict, device):\n","    \"\"\"Warm-start BPR embeddings from WALS factors.\"\"\"\n","    ib  = torch.from_numpy(wals[\"item_biases\"]).float()  # [n_items]\n","    bpr_model.item_bias.weight.data.copy_(ib.unsqueeze(1).to(device))\n","    print(\"    BPR initialized as residual corrector on top of WALS\", flush=True)\n","\n","    if bpr_model.use_wals_features:\n","        # Sample 100k random (u, i) pairs to estimate WALS score distribution\n","        n_users = wals[\"user_factors\"].shape[0]\n","        n_items = wals[\"item_factors\"].shape[0]\n","        rng = np.random.default_rng(42)\n","        sample_u = rng.integers(0, n_users, 100_000)\n","        sample_i = rng.integers(0, n_items, 100_000)\n","\n","        uf_np = wals[\"user_factors\"]\n","        itf_np = wals[\"item_factors\"]\n","        ub_np = wals[\"user_biases\"]\n","        ib_np = wals[\"item_biases\"]\n","        gm_np = wals[\"global_mean\"]\n","\n","        sample_scores = (gm_np + ub_np[sample_u] + ib_np[sample_i]\n","                         + (uf_np[sample_u] * itf_np[sample_i]).sum(axis=1))\n","\n","        wals_mean = float(sample_scores.mean())\n","        wals_std  = float(sample_scores.std()) + 1e-8\n","\n","        print(f\"    WALS score stats: mean={wals_mean:.3f}  std={wals_std:.3f}\", flush=True)\n","\n","        # Store as buffers so they travel with the model to device\n","        bpr_model.register_buffer(\"wals_mean\", torch.tensor(wals_mean).to(device))\n","        bpr_model.register_buffer(\"wals_std\",  torch.tensor(wals_std).to(device))\n","\n","# ── 4. WALS CANDIDATE GENERATION ─────────────────────────────────────────────\n","def get_wals_candidates(wals: dict, u_idx: int, n_candidates: int) -> np.ndarray:\n","    \"\"\"Top-N item indices from WALS for a given user index.\"\"\"\n","    uf   = wals[\"user_factors\"]\n","    if_  = wals[\"item_factors\"]\n","    ub   = wals[\"user_biases\"]\n","    ib   = wals[\"item_biases\"]\n","    gm   = wals[\"global_mean\"]\n","    n    = len(ib)\n","    if u_idx >= 0:\n","        scores = gm + ub[u_idx] + ib + uf[u_idx] @ if_.T\n","    else:\n","        scores = gm + ib\n","    k = min(n_candidates, n)\n","    top = np.argpartition(-scores, k-1)[:k]\n","    return top[np.argsort(-scores[top])]\n","\n","# ── 5. BUILD INTERACTION DICTS ────────────────────────────────────────────────\n","def build_interaction_dicts(train_df, test_df, u_enc, i_enc, wals, device,\n","                             n_candidates=N_CANDIDATES):\n","    \"\"\"\n","    Returns:\n","        train_pos_matrix: CSR matrix of train positives\n","        train_hard_neg:   {u_idx: array of candidate item indices that are NOT positive}\n","        test_pos:         {u_idx: set of positive item indices from test}\n","        test_candidates:  {u_idx: array of candidate indices (WALS top-N)}\n","        eval_users:       list of u_idx that have ≥1 test positive\n","    \"\"\"\n","    print(\"  Building train positives CSR matrix...\", flush=True)\n","\n","    # Map IDs directly to numpy arrays and delete train_df early to reclaim memory\n","    u_mapped = train_df[\"CustomerID\"].map(u_enc).values\n","    i_mapped = train_df[\"MovieID\"].map(i_enc).values\n","    ratings = train_df[\"Rating\"].values\n","    del train_df; gc.collect()\n","\n","    n_users = len(u_enc)\n","    n_items = len(i_enc)\n","\n","    valid_mask = (ratings >= RELEVANCE_THRESH) & (~np.isnan(u_mapped)) & (~np.isnan(i_mapped))\n","    rows = u_mapped[valid_mask].astype(np.int32)\n","    cols = i_mapped[valid_mask].astype(np.int32)\n","    del u_mapped, i_mapped, ratings, valid_mask; gc.collect()\n","\n","    data = np.ones(len(rows), dtype=np.bool_)\n","    train_pos_matrix = csr_matrix((data, (rows, cols)), shape=(n_users, n_items))\n","    del data; gc.collect()\n","\n","    print(\"  Mapping test positives...\", flush=True)\n","    test_u = test_df[\"CustomerID\"].map(u_enc).values\n","    test_i = test_df[\"MovieID\"].map(i_enc).values\n","    test_ratings = test_df[\"Rating\"].values\n","    del test_df; gc.collect()\n","\n","    test_mask = (test_ratings >= RELEVANCE_THRESH) & (~np.isnan(test_u)) & (~np.isnan(test_i))\n","    test_u_pos = test_u[test_mask].astype(np.int32)\n","    test_i_pos = test_i[test_mask].astype(np.int32)\n","    del test_u, test_i, test_ratings, test_mask; gc.collect()\n","\n","    # We want users that have both train positives and test positives\n","    train_user_mask = np.diff(train_pos_matrix.indptr) > 0\n","    test_users_with_pos = np.unique(test_u_pos)\n","\n","    # Ensure they are within valid bounds of train_user_mask\n","    valid_test_users = test_users_with_pos[(test_users_with_pos >= 0) & (test_users_with_pos < n_users)]\n","    eval_candidates = valid_test_users[train_user_mask[valid_test_users]]\n","\n","    # Subsample eval_users\n","    if len(eval_candidates) > MAX_EVAL_USERS:\n","        rng = np.random.default_rng(RANDOM_SEED)\n","        eval_users = rng.choice(eval_candidates, MAX_EVAL_USERS, replace=False).tolist()\n","    else:\n","        eval_users = eval_candidates.tolist()\n","\n","    eval_users_set = set(eval_users)\n","    test_pos = {}\n","    for u, i in zip(test_u_pos, test_i_pos):\n","        if u in eval_users_set:\n","            test_pos.setdefault(int(u), set()).add(int(i))\n","    del test_u_pos, test_i_pos; gc.collect()\n","\n","    print(\"  Generating WALS candidates using GPU acceleration...\", flush=True)\n","    # Get all users who have train positives\n","    all_users_needed = np.where(train_user_mask)[0]\n","\n","    # Pre-load WALS tensors to GPU/device for batch candidate generation\n","    uf = torch.from_numpy(wals[\"user_factors\"]).to(device)\n","    iff = torch.from_numpy(wals[\"item_factors\"]).to(device)\n","    ub = torch.from_numpy(wals[\"user_biases\"]).to(device)\n","    ib = torch.from_numpy(wals[\"item_biases\"]).to(device)\n","    gm = wals[\"global_mean\"]\n","\n","    train_hard_neg = {}\n","    test_candidates = {}\n","\n","    batch_size = 10000\n","    print(\"  Filtering positives from candidates batch-by-batch...\", flush=True)\n","    for i in tqdm(range(0, len(all_users_needed), batch_size), desc=\"Candidates\"):\n","        batch_u = all_users_needed[i:i+batch_size]\n","        idx_dtype = torch.long if device.type != \"mps\" else torch.int32\n","        batch_u_t = torch.from_numpy(batch_u).to(device, dtype=idx_dtype)\n","\n","        # Compute scores: shape [batch_size, n_items]\n","        with torch.no_grad():\n","            scores = gm + ub[batch_u_t].unsqueeze(1) + ib.unsqueeze(0) + torch.matmul(uf[batch_u_t], iff.T)\n","            # Get top-k indices: shape [batch_size, n_candidates]\n","            _, top_indices = torch.topk(scores, k=n_candidates, dim=1, largest=True, sorted=True)\n","            batch_cands = top_indices.cpu().numpy()\n","\n","        for idx, u in enumerate(batch_u):\n","            cands = batch_cands[idx]\n","            pos_items = train_pos_matrix.indices[train_pos_matrix.indptr[u]:train_pos_matrix.indptr[u+1]]\n","            pos_set = set(pos_items)\n","\n","            # Filter out positives to get hard negatives, cast to int32 to prevent Numba alignment issues\n","            hard_negs = np.array([c for c in cands if c not in pos_set], dtype=np.int32)\n","            train_hard_neg[int(u)] = hard_negs\n","\n","            if u in eval_users_set:\n","                # Filter out training positives (seen items) from evaluation candidates to prevent wasted slots\n","                test_candidates[int(u)] = hard_negs.copy()\n","\n","    # Free GPU variables\n","    del uf, iff, ub, ib; gc.collect()\n","    if device.type == \"cuda\":\n","        torch.cuda.empty_cache()\n","\n","    print(f\"    {train_pos_matrix.nnz:,} train positives\")\n","    print(f\"    {len(eval_users):,} users for MAP eval\")\n","    return train_pos_matrix, train_hard_neg, test_pos, test_candidates, eval_users\n","\n","# ── 6. EVALUATION ─────────────────────────────────────────────────────────────\n","@torch.no_grad()\n","def evaluate(bpr_model, wals, test_pos, test_candidates, eval_users,\n","             device, k=TOP_K, wals_tensors=None):\n","    \"\"\"\n","    MAP@k and NDCG@k.\n","    Ranks the WALS candidate set using the BPR model scores.\n","    \"\"\"\n","    bpr_model.eval()\n","    map_scores, ndcg_scores = [], []\n","\n","    for u_idx in tqdm(eval_users, desc=\"Eval\", leave=False, mininterval=1.0):\n","        cands    = test_candidates.get(u_idx)\n","        pos_set  = test_pos.get(u_idx, set())\n","        if cands is None or not pos_set:\n","            continue\n","\n","        # BPR scores over candidates\n","        scores   = bpr_model.score_candidates(u_idx, cands, device, wals_tensors)\n","        order    = np.argsort(-scores)\n","        ranked   = cands[order]\n","\n","        # MAP@k\n","        hits, prec_sum = 0, 0.0\n","        for rank, iid in enumerate(ranked[:k], 1):\n","            if iid in pos_set:\n","                hits += 1\n","                prec_sum += hits / rank\n","        map_scores.append(prec_sum / min(len(pos_set), k))\n","\n","        # NDCG@k\n","        dcg  = sum((1 / np.log2(r + 2)) for r, iid in enumerate(ranked[:k])\n","                   if iid in pos_set)\n","        idcg = sum(1 / np.log2(r + 2) for r in range(min(len(pos_set), k)))\n","        ndcg_scores.append(dcg / idcg if idcg > 0 else 0.0)\n","\n","    map_k  = float(np.mean(map_scores))  if map_scores  else 0.0\n","    ndcg_k = float(np.mean(ndcg_scores)) if ndcg_scores else 0.0\n","    return map_k, ndcg_k\n","\n","def make_scheduler(opt, warmup_epochs=3, total_epochs=BPR_EPOCHS):\n","    def lr_lambda(epoch):\n","        if epoch < warmup_epochs:\n","            return float(epoch) / warmup_epochs          # linear warmup\n","        # flat until epoch 20, then cosine decay\n","        progress = (epoch - warmup_epochs) / max(total_epochs - warmup_epochs, 1)\n","        return 0.5 * (1.0 + np.cos(np.pi * progress))\n","    return torch.optim.lr_scheduler.LambdaLR(opt, lr_lambda)\n","\n","# ── 7. TRAINING LOOP (FLAT RAM BATCH LOADER, FAST) ────────────────────────────\n","def train_bpr(bpr_model, positives, neg_indptr, neg_indices, wals, test_pos, test_candidates,\n","              eval_users, device, epochs=BPR_EPOCHS, batch_size=BPR_BATCH, neg_per_pos=NEG_SAMPLES):\n","    opt = torch.optim.Adam([\n","        {\"params\": [p for n, p in bpr_model.named_parameters()\n","                    if \"wals_w\" not in n and \"residual_scale\" not in n],\n","         \"lr\": BPR_LR},\n","        {\"params\": [p for n, p in bpr_model.named_parameters()\n","                    if \"wals_w\" in n or \"residual_scale\" in n],\n","         \"lr\": BPR_LR * 0.1},   # 10x slower for the scalar weights\n","    ])\n","    scheduler = make_scheduler(opt, warmup_epochs=3, total_epochs=epochs)\n","    scaler = torch.cuda.amp.GradScaler(enabled=(device.type == \"cuda\"))\n","\n","    num_pos = len(positives)\n","    pos_batch_size = batch_size // neg_per_pos\n","    n_items = len(wals[\"item_biases\"])\n","\n","    # Pre-extract columns once (avoids repeated fancy-indexing on 2D array)\n","    pos_users = positives[:, 0]\n","    pos_items = positives[:, 1]\n","\n","    # Pre-load WALS tensors to GPU/device if WALS features are active\n","    if bpr_model.use_wals_features:\n","        wals_uf = torch.from_numpy(wals[\"user_factors\"]).to(device)\n","        wals_if = torch.from_numpy(wals[\"item_factors\"]).to(device)\n","        wals_ub = torch.from_numpy(wals[\"user_biases\"]).to(device)\n","        wals_ib = torch.from_numpy(wals[\"item_biases\"]).to(device)\n","        wals_gm = wals[\"global_mean\"]\n","        wals_tensors = (wals_uf, wals_if, wals_ub, wals_ib, wals_gm)\n","\n","        @torch.no_grad()\n","        def wals_score(u, i):\n","            return wals_gm + wals_ub[u] + wals_ib[i] + (wals_uf[u] * wals_if[i]).sum(-1)\n","    else:\n","        wals_tensors = None\n","\n","    rng = np.random.default_rng(RANDOM_SEED)\n","    best_map, best_state = 0.0, None\n","    epochs_no_improve = 0\n","\n","    for epoch in range(1, epochs + 1):\n","        t0 = time.time()\n","\n","        # Curriculum hard negatives ratio: capped at 0.36 to prevent overfitting to hard negatives\n","        hard_ratio = min(0.36, epoch / epochs)\n","\n","        # Shuffle once per epoch\n","        shuffled = rng.permutation(num_pos).astype(np.int32)\n","\n","        bpr_model.train()\n","        total_loss = torch.zeros((), device=device)\n","        total_bpr  = torch.zeros((), device=device)\n","        n_batches  = 0\n","\n","        # Loop through positives, expand by neg_per_pos on-the-fly per batch to save RAM\n","        for start_idx in tqdm(range(0, num_pos, pos_batch_size), desc=f\"Epoch {epoch}\",\n","                               leave=False, mininterval=1.0):\n","            end_idx = min(start_idx + pos_batch_size, num_pos)\n","\n","            u_batch_pos = pos_users[shuffled[start_idx:end_idx]]\n","            p_batch_pos = pos_items[shuffled[start_idx:end_idx]]\n","\n","            u_batch = np.repeat(u_batch_pos, neg_per_pos)\n","            p_batch = np.repeat(p_batch_pos, neg_per_pos)\n","\n","            # Sample negatives on CPU (mixed hard/random negatives)\n","            neg_batch = sample_negatives_mixed(u_batch, neg_indptr, neg_indices, n_items, hard_ratio=hard_ratio)\n","\n","            idx_dtype = torch.long if device.type != \"mps\" else torch.int32\n","            u   = torch.from_numpy(u_batch).to(device, dtype=idx_dtype)\n","            pos = torch.from_numpy(p_batch).to(device, dtype=idx_dtype)\n","            neg = torch.from_numpy(neg_batch).to(device, dtype=idx_dtype)\n","\n","            # Compute WALS scores for the batch on device if required\n","            if bpr_model.use_wals_features:\n","                wals_pos = wals_score(u, pos)\n","                wals_neg = wals_score(u, neg)\n","            else:\n","                wals_pos = wals_neg = None\n","\n","            opt.zero_grad(set_to_none=True)\n","\n","            if device.type == \"cuda\":\n","                with torch.cuda.amp.autocast():\n","                    loss, bpr_raw = bpr_model(u, pos, neg, wals_pos, wals_neg)\n","                scaler.scale(loss).backward()\n","                scaler.unscale_(opt)\n","                nn.utils.clip_grad_norm_(bpr_model.parameters(), 1.0)\n","                scaler.step(opt)\n","                scaler.update()\n","            else:\n","                loss, bpr_raw = bpr_model(u, pos, neg, wals_pos, wals_neg)\n","                loss.backward()\n","                nn.utils.clip_grad_norm_(bpr_model.parameters(), 1.0)\n","                opt.step()\n","\n","            # Accumulate on-device — no host sync until end of epoch\n","            total_loss += loss.detach()\n","            total_bpr  += bpr_raw\n","            n_batches  += 1\n","\n","        scheduler.step()\n","        avg_loss = (total_loss / max(n_batches, 1)).item()\n","        avg_bpr  = (total_bpr  / max(n_batches, 1)).item()\n","\n","        # evaluate every 3 epochs and on the last\n","        wals_w_val = bpr_model.wals_w.item() if bpr_model.use_wals_features else 0.0\n","        if epoch % 3 == 0 or epoch == epochs:\n","            map_k, ndcg_k = evaluate(bpr_model, wals, test_pos, test_candidates,\n","                                     eval_users, device, k=TOP_K, wals_tensors=wals_tensors)\n","            flag = \"\"\n","            if map_k > best_map:\n","                best_map   = map_k\n","                best_state = {k: v.clone() for k, v in bpr_model.state_dict().items()}\n","                epochs_no_improve = 0\n","                flag = \" *\"\n","            else:\n","                epochs_no_improve += 3\n","                flag = \"\"\n","            print(f\"  Epoch {epoch:2d}  loss={avg_loss:.4f}  bpr={avg_bpr:.4f}  \"\n","                  f\"hard_ratio={hard_ratio:.2f}  wals_w={wals_w_val:.4f}  MAP@{TOP_K}={map_k:.4f}  NDCG@{TOP_K}={ndcg_k:.4f}\"\n","                  f\"  ({time.time()-t0:.1f}s){flag}\", flush=True)\n","\n","            if epochs_no_improve >= PATIENCE * 3:\n","                print(f\"  Early stopping at epoch {epoch}\")\n","                break\n","        else:\n","            print(f\"  Epoch {epoch:2d}  loss={avg_loss:.4f}  bpr={avg_bpr:.4f}  \"\n","                  f\"hard_ratio={hard_ratio:.2f}  wals_w={wals_w_val:.4f}  ({time.time()-t0:.1f}s)\", flush=True)\n","\n","        gc.collect()\n","\n","    # restore best\n","    if best_state:\n","        bpr_model.load_state_dict(best_state)\n","    return best_map\n","\n","# ── 8. INFERENCE HELPER ───────────────────────────────────────────────────────\n","def recommend(bpr_model, wals, u_enc, i_enc, customer_id, train_pos_set=None,\n","              n_candidates=N_CANDIDATES, k=TOP_K, device=torch.device(\"cpu\"), wals_tensors=None):\n","    \"\"\"\n","    End-to-end recommendation for a single customer.\n","    train_pos_set: set of item indices already rated by this user (to exclude)\n","    Returns list of (MovieID, bpr_score) top-k.\n","    \"\"\"\n","    idx_to_movie = {v: k for k, v in i_enc.items()}\n","    u_idx = u_enc.get(customer_id, -1)\n","    cands = get_wals_candidates(wals, u_idx, n_candidates)\n","\n","    # Filter out already-seen items\n","    if train_pos_set is not None:\n","        cands = np.array([c for c in cands if c not in train_pos_set], dtype=np.int32)\n","\n","    bpr_model.eval()\n","    with torch.no_grad():\n","        scores = bpr_model.score_candidates(u_idx, cands, device, wals_tensors)\n","    order = np.argsort(-scores)[:k]\n","    return [(idx_to_movie[cands[j]], float(scores[j])) for j in order]\n","\n","# ── 9. MAIN ───────────────────────────────────────────────────────────────────\n","def main():\n","    parser = argparse.ArgumentParser()\n","    parser.add_argument(\"--candidates\",        type=int,  default=N_CANDIDATES)\n","    parser.add_argument(\"--factors\",           type=int,  default=BPR_FACTORS)\n","    parser.add_argument(\"--epochs\",            type=int,  default=BPR_EPOCHS)\n","    parser.add_argument(\"--batch\",             type=int,  default=BPR_BATCH)\n","    parser.add_argument(\"--neg_samples\",       type=int,  default=NEG_SAMPLES)\n","    parser.add_argument(\"--use_wals_features\", action=\"store_true\", default=True,\n","                        help=\"Include WALS score as auxiliary BPR feature\")\n","    args, unknown = parser.parse_known_args()\n","    args.use_wals_features = True  # Enable WALS auxiliary features by default as they improve performance significantly\n","\n","    device = (torch.device(\"cuda\") if torch.cuda.is_available()\n","              else torch.device(\"mps\") if torch.backends.mps.is_available()\n","              else torch.device(\"cpu\"))\n","    print(f\"Device: {device}\", flush=True)\n","\n","    data_dir = find_data_dir()\n","    save_dir = find_save_dir()\n","    wals_path = find_wals(save_dir)\n","\n","    print(f\"\\n[1] Loading WALS model from {wals_path}\")\n","    with open(wals_path, \"rb\") as f:\n","        wals = pickle.load(f)\n","    u_enc   = wals[\"u_enc\"]\n","    i_enc   = wals[\"i_enc\"]\n","    n_users = len(u_enc)\n","    n_items = len(i_enc)\n","    print(f\"    {n_users:,} users  {n_items:,} items\")\n","\n","    print(\"\\n[2] Loading interaction data\")\n","    train_df = load_df(os.path.join(data_dir, \"train.parquet\"))\n","    test_df  = load_df(os.path.join(data_dir, \"test.parquet\"))\n","\n","    print(\"\\n[3] Building interaction data\")\n","    (train_pos_matrix, train_hard_neg,\n","     test_pos, test_candidates, eval_users) = build_interaction_dicts(\n","        train_df, test_df, u_enc, i_enc, wals, device, args.candidates)\n","\n","    # Empty GPU cache if using CUDA to free memory after candidate generation\n","    if device.type == \"cuda\":\n","        torch.cuda.empty_cache()\n","    gc.collect()\n","\n","    print(\"\\n[4] Building flat train positives array\")\n","    rows = np.repeat(np.arange(n_users, dtype=np.int32), np.diff(train_pos_matrix.indptr))\n","    cols = train_pos_matrix.indices.astype(np.int32)\n","    positives = np.column_stack((rows, cols))\n","    print(f\"    Total positive pairs: {len(positives):,}\")\n","\n","    # Extract demo user's training positives before deleting matrix\n","    sample_cid = next(iter(u_enc))\n","    sample_u_idx = u_enc[sample_cid]\n","    sample_train_pos = set(train_pos_matrix.indices[train_pos_matrix.indptr[sample_u_idx]:train_pos_matrix.indptr[sample_u_idx+1]])\n","\n","    del train_pos_matrix; gc.collect()\n","\n","    print(\"\\n[5] Converting hard negatives to flat array pointers\")\n","    # Convert hard negatives dictionary to memory-efficient CSR-like pointers\n","    neg_indptr = np.zeros(n_users + 1, dtype=np.int32)\n","    lengths = np.zeros(n_users, dtype=np.int32)\n","    for u, negs in train_hard_neg.items():\n","        lengths[u] = len(negs)\n","    neg_indptr[1:] = np.cumsum(lengths)\n","\n","    neg_indices = np.empty(neg_indptr[-1], dtype=np.int32)\n","    for u, negs in train_hard_neg.items():\n","        start = neg_indptr[u]\n","        end = neg_indptr[u+1]\n","        neg_indices[start:end] = negs\n","\n","    del train_hard_neg; gc.collect()\n","\n","    print(\"\\n[6] Building BPR model\")\n","    bpr_model = BPRModel(n_users, n_items,\n","                         factors=args.factors,\n","                         use_wals_features=args.use_wals_features).to(device)\n","    init_from_wals(bpr_model, wals, device)\n","    total_params = sum(p.numel() for p in bpr_model.parameters())\n","    print(f\"    Parameters: {total_params:,}\")\n","\n","    if args.use_wals_features:\n","        print(\"    WALS features enabled: True\")\n","        # Sanity check forward & backward pass to verify gradients flow to wals_w\n","        idx_dtype = torch.long if device.type != \"mps\" else torch.int32\n","        dummy_u = torch.tensor([0, 1], dtype=idx_dtype, device=device)\n","        dummy_pos = torch.tensor([10, 20], dtype=idx_dtype, device=device)\n","        dummy_neg = torch.tensor([30, 40], dtype=idx_dtype, device=device)\n","        dummy_wals_pos = torch.tensor([1.5, 2.5], dtype=torch.float, device=device)\n","        dummy_wals_neg = torch.tensor([0.5, 1.5], dtype=torch.float, device=device)\n","\n","        loss, bpr_raw = bpr_model(dummy_u, dummy_pos, dummy_neg, dummy_wals_pos, dummy_wals_neg)\n","        loss.backward()\n","        if bpr_model.wals_w_raw.grad is not None:\n","            print(\"    Verification: WALS features successfully integrated. Gradients are flowing to wals_w.\")\n","        else:\n","            print(\"    Warning: Gradients are NOT flowing to wals_w.\")\n","        bpr_model.zero_grad()\n","    else:\n","        print(\"    WALS features enabled: False\")\n","\n","    print(f\"\\n[7] Training BPR ({args.epochs} epochs, \"\n","          f\"batch={args.batch}, neg/pos={args.neg_samples})\")\n","    best_map = train_bpr(bpr_model, positives, neg_indptr, neg_indices, wals,\n","                         test_pos, test_candidates, eval_users,\n","                         device, epochs=args.epochs, batch_size=args.batch, neg_per_pos=args.neg_samples)\n","\n","    print(f\"\\n  Best MAP@{TOP_K} = {best_map:.4f}\")\n","\n","    # Final full eval\n","    if args.use_wals_features:\n","        wals_tensors = (\n","            torch.from_numpy(wals[\"user_factors\"]).to(device),\n","            torch.from_numpy(wals[\"item_factors\"]).to(device),\n","            torch.from_numpy(wals[\"user_biases\"]).to(device),\n","            torch.from_numpy(wals[\"item_biases\"]).to(device),\n","            wals[\"global_mean\"]\n","        )\n","    else:\n","        wals_tensors = None\n","\n","    map_k, ndcg_k = evaluate(bpr_model, wals, test_pos, test_candidates,\n","                              eval_users, device, k=TOP_K, wals_tensors=wals_tensors)\n","    print(f\"\\n{'='*50}\")\n","    print(f\"  Stage-2 BPR  MAP@{TOP_K}  = {map_k:.4f}\")\n","    print(f\"  Stage-2 BPR  NDCG@{TOP_K} = {ndcg_k:.4f}\")\n","    print(f\"{'='*50}\")\n","\n","    # Save\n","    save_path = os.path.join(save_dir, \"bpr_stage2.pkl\")\n","    with open(save_path, \"wb\") as f:\n","        pickle.dump({\n","            \"state_dict\":        bpr_model.state_dict(),\n","            \"n_users\":           n_users,\n","            \"n_items\":           n_items,\n","            \"factors\":           args.factors,\n","            \"use_wals_features\": args.use_wals_features,\n","            \"u_enc\":             u_enc,\n","            \"i_enc\":             i_enc,\n","        }, f)\n","    print(f\"  Saved → {save_path}\")\n","\n","    # Demo: top-10 for first user in u_enc\n","    recs = recommend(bpr_model, wals, u_enc, i_enc, sample_cid, train_pos_set=sample_train_pos,\n","                     n_candidates=args.candidates, k=TOP_K, device=device, wals_tensors=wals_tensors)\n","    print(f\"\\n  Sample recs for CustomerID={sample_cid}:\")\n","    for movie_id, score in recs:\n","        print(f\"    MovieID={movie_id:6d}  score={score:.4f}\")\n","\n","if __name__ == \"__main__\":\n","    main()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000,"referenced_widgets":["033ef94597494866bdf6a0fced407e07","c1b580994fbf4af5b92fbe1f6ec9e476","286a6086f74c457cb8bd786793a577b5","f996feb093c14168b5c6afbfabec5f99","5ccf39e8ca3944ceb7ee6e37d4ce5dd2","d3944a6e5e074abd9a07fd1e4a319121","9a975e9f6c97439393514b8655e377a0","29d509298a364edb8a28d53fd65ead00","5816cb33a03642abaa30664263231d86","034d8a5300414e479c8f650a86c3b27a","d6c89a5869bd45cfb81843f848b05fdf","a1ea37715f114a04b5e03fc1fe26d0a0","06b34c85f8a14e74b74ab77f4ead7b66","693e250821274edea008650c67b352e8","71a2bbdc96c6455bba8931d954b3cdee","e2b0323d21f7479886d999e1ad3573f8","46390dadde0a40b48b85e3f6c871370d","6ed3eea287dd405aa9b61e3fc2486484","b2eec2a325184cf6946373b56d573e69","178e27908c4c42faa0a0835b3f9dfd3d","e0213c8f15c246279f6ba09ef8f72642","4fdb6d62579c4d3a8d82512822d7134a","105b02df3c7546769cf9945b436a1ff4","e8e9c5585932489682087f0159be0135","c6f8017412e64e159366a4aecf68d243","eff1efbb37f54141b4dc9750e326fef4","5b5444670c3648719538ed8ac2a492f6","7cb71058dfac4164981a9baa258a18b7","027d4b67189848588658aca81c5072d0","f81c7a62598a4c3e9e14b2abed11e99e","746615f781e1474cbbf8943bdb5f9869","0303b4c2971146a393900f96bf267aab","48078abaf28745fa87891d692a958662","7778953c68ab43efa3b3b95b1abd1542","8644fe3ba9b247b49da55e64a9632550","dc742c9f0f954de7a91ceddf42180e94","cd16daa5dbb04a6795c418c1466d5cab","a1d653ea844446628d9aa8992563c02b","20d90dcf378f473c9c7caff26882a7ff","e4eea2d67941428c8e81cddf66d451fe","97c19ef09f4c452d9b6a6fe6599b7b4b","d177630e28ae4bbabffa5d9c2c65c442","d922bb0cf3bb453aa8cf25ab62392a5c","2ea