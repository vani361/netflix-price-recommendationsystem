 the WALS stage-1 model, the trained Stage-2 BPR model, and the test set,\n","then computes evaluation metrics (MAP@10, NDCG@10) separately for:\n","  - All users (with >=1 test positive interaction)\n","  - Warm users (uniquely present in training set)\n","  - Cold users (not present in training set / unseen during training)\n","\n","Optimized via pure CPU NumPy matrix operations to run in seconds.\n","\"\"\"\n","\n","import os, sys, pickle, gc, collections\n","import numpy as np\n","import pandas as pd\n","from tqdm import tqdm\n","import torch\n","\n","RELEVANCE_THRESH = 3.5\n","TOP_K = 10\n","N_CANDIDATES = 2000\n","\n","def load_df(path):\n","    if path.endswith(\".parquet\"):\n","        import pyarrow.parquet as pq\n","        cols = pq.ParquetFile(path).schema.names\n","    else:\n","        cols = list(pd.read_csv(path, nrows=0).columns)\n","    col_map = {}\n","    for c in cols:\n","        cl = c.lower()\n","        if cl in (\"customerid\", \"userid\", \"user_id\", \"customer_id\"):\n","            col_map[\"CustomerID\"] = c\n","        elif cl in (\"movieid\", \"itemid\", \"movie_id\", \"item_id\"):\n","            col_map[\"MovieID\"] = c\n","        elif cl in (\"rating\", \"ratings\"):\n","            col_map[\"Rating\"] = c\n","    load = [col_map[k] for k in [\"CustomerID\", \"MovieID\", \"Rating\"] if k in col_map]\n","    df = (pd.read_parquet(path, columns=load) if path.endswith(\".parquet\")\n","          else pd.read_csv(path, usecols=load))\n","    df.rename(columns={v: k for k, v in col_map.items()}, inplace=True)\n","    df = df.loc[:, ~df.columns.duplicated()]\n","    df[\"CustomerID\"] = df[\"CustomerID\"].astype(\"int32\")\n","    df[\"MovieID\"] = df[\"MovieID\"].astype(\"int32\")\n","    if \"Rating\" in df.columns:\n","        df[\"Rating\"] = df[\"Rating\"].astype(\"float32\")\n","    return df\n","\n","def softplus(x):\n","    # Stable softplus in NumPy\n","    return np.log1p(np.exp(x)) if x < 20.0 else x\n","\n","def main():\n","    # 1. Paths\n","    wals_path = \"/content/drive/Shareddrives/netflixrecommendationsystem/wals_stage1.pkl\"\n","    bpr_path = \"/content/drive/Shareddrives/netflixrecommendationsystem/bpr_stage3.pkl\"\n","    if not os.path.exists(wals_path):\n","        print(f\"Error: WALS model not found at {wals_path}\")\n","        sys.exit(1)\n","    if not os.path.exists(bpr_path):\n","        print(f\"Error: BPR model not found at {bpr_path}\")\n","        sys.exit(1)\n","\n","    print(f\"Loading WALS model from {wals_path}...\")\n","    with open(wals_path, \"rb\") as f:\n","        wals = pickle.load(f)\n","    u_enc = wals[\"u_enc\"]\n","    i_enc = wals[\"i_enc\"]\n","    n_users = len(u_enc)\n","    n_items = len(i_enc)\n","    print(f\"  WALS catalog: {n_users:,} users, {n_items:,} items\")\n","\n","    print(f\"Loading BPR model from {bpr_path}...\")\n","    with open(bpr_path, \"rb\") as f:\n","        bpr = pickle.load(f)\n","    state_dict = bpr[\"state_dict\"]\n","\n","    # Extract weights to NumPy for speed\n","    print(\"Extracting weights to NumPy CPU space for ultra-fast matching...\")\n","    bpr_uf = state_dict[\"user_emb.weight\"].cpu().numpy()\n","    bpr_if = state_dict[\"item_emb.weight\"].cpu().numpy()\n","    bpr_ib = state_dict[\"item_bias.weight\"].cpu().numpy().squeeze(-1)\n","\n","    # Handle potentially missing keys from older checkpoints\n","    if \"residual_scale\" in state_dict:\n","        residual_scale = state_dict[\"residual_scale\"].cpu().item()\n","    else:\n","        print(\"  Warning: 'residual_scale' not found in state dict. Defaulting to 0.1.\")\n","        residual_scale = 0.1\n","\n","    use_wals_features = bpr.get(\"use_wals_features\", True)\n","    if use_wals_features:\n","        if \"wals_w_raw\" in state_dict:\n","            wals_w_raw = state_dict[\"wals_w_raw\"].cpu().item()\n","        else:\n","            print(\"  Warning: 'wals_w_raw' not found in state dict. Defaulting to 0.5.\")\n","            wals_w_raw = 0.5\n","        wals_w = softplus(wals_w_raw)\n","        wals_mean = state_dict[\"wals_mean\"].cpu().item() if \"wals_mean\" in state_dict else 3.322\n","        wals_std = state_dict[\"wals_std\"].cpu().item() if \"wals_std\" in state_dict else 1.353\n","        print(f\"  Scalar parameters: residual_scale={softplus(residual_scale):.4f}, wals_w={wals_w:.4f}, mean={wals_mean:.3f}, std={wals_std:.3f}\")\n","    else:\n","        print(f\"  Scalar parameters: residual_scale={softplus(residual_scale):.4f} (WALS blend features disabled)\")\n","\n","    wals_uf = wals[\"user_factors\"]\n","    wals_if = wals[\"item_factors\"]\n","    wals_ub = wals[\"user_biases\"]\n","    wals_ib = wals[\"item_biases\"]\n","    wals_gm = wals[\"global_mean\"]\n","\n","    # 2. Build train positives to filter seen movies for warm users\n","    print(\"\\nLoading train.parquet to build train positive sets...\")\n","    train_df = load_df(\"/content/drive/Shareddrives/netflixrecommendationsystem/dataset/train.parquet\")\n","\n","    u_mapped = train_df[\"CustomerID\"].map(u_enc).values\n","    i_mapped = train_df[\"MovieID\"].map(i_enc).values\n","    ratings = train_df[\"Rating\"].values\n","    del train_df; gc.collect()\n","\n","    mask = (ratings >= RELEVANCE_THRESH) & (~np.isnan(u_mapped)) & (~np.isnan(i_mapped))\n","    u_mapped = u_mapped[mask].astype(np.int32)\n","    i_mapped = i_mapped[mask].astype(np.int32)\n","    del ratings, mask; gc.collect()\n","\n","    train_pos = collections.defaultdict(set)\n","    print(\"Hashing training positives...\")\n","    for u_idx, i_idx in zip(u_mapped, i_mapped):\n","        train_pos[u_idx].add(i_idx)\n","    del u_mapped, i_mapped; gc.collect()\n","    print(f\"  Mapped positives for {len(train_pos):,} warm users.\")\n","\n","    # 3. Load and prepare test set\n","    print(\"\\nLoading test.parquet...\")\n","    test_df = load_df(\"/content/drive/Shareddrives/netflixrecommendationsystem/dataset/test.parquet\")\n","\n","    # Filter test set positives\n","    test_pos_df = test_df[test_df[\"Rating\"] >= RELEVANCE_THRESH]\n","    del test_df; gc.collect()\n","\n","    # Hash positives: CustomerID (original) -> set of MovieID indices (mapped)\n","    print(\"Mapping and hashing test positives...\")\n","    raw_test_users = test_pos_df[\"CustomerID\"].values\n","    raw_test_movies = test_pos_df[\"MovieID\"].values\n","    del test_pos_df; gc.collect()\n","\n","    # We group by original CustomerID\n","    test_pos = collections.defaultdict(set)\n","    for cid, mid in zip(raw_test_users, raw_test_movies):\n","        i_idx = i_enc.get(mid, -1)\n","        if i_idx >= 0:\n","            test_pos[cid].add(i_idx)\n","\n","    eval_users = [cid for cid, pos_set in test_pos.items() if len(pos_set) > 0]\n","    print(f\"  Found {len(eval_users):,} users in test set with >=1 positive item.\")\n","\n","    # 4. Cohort splitting\n","    print(\"\\nCategorizing users into cohorts...\")\n","    warm_users_list = []\n","    cold_users_list = []\n","\n","    for cid in eval_users:\n","        if cid in u_enc:\n","            warm_users_list.append(cid)\n","        else:\n","            cold_users_list.append(cid)\n","\n","    print(f\"  Cohort Warm: {len(warm_users_list):,} users\")\n","    print(f\"  Cohort Cold: {len(cold_users_list):,} users\")\n","    print(f\"  Cohort All:  {len(eval_users):,} users\")\n","\n","    # 5. Cohort evaluation function\n","    def evaluate_cohort(user_cohort, name):\n","        if not user_cohort:\n","            print(f\"\\nCohort [{name}]: No users present.\")\n","            return\n","\n","        map_scores = []\n","        ndcg_scores = []\n","\n","        # Precompute fallback candidates for cold users to avoid generating them repeatedly\n","        # Cold WALS candidates are based on item biases alone\n","        if name == \"Cold\" or name == \"All\":\n","            # get_wals_candidates with u_idx = -1\n","            scores_cold_wals = wals_gm + wals_ib\n","            k_cands = min(N_CANDIDATES, n_items)\n","            top_cold = np.argpartition(-scores_cold_wals, k_cands-1)[:k_cands]\n","            cold_candidates_base = top_cold[np.argsort(-scores_cold_wals[top_cold])].astype(np.int32)\n","\n","            # Precompute cold BPR scores for these candidates\n","            # residual = item_bias\n","            cold_residual = bpr_ib[cold_candidates_base]\n","            cold_bpr_residual = softplus(residual_scale) * cold_residual\n","            if use_wals_features:\n","                cold_wals_score = wals_gm + wals_ib[cold_candidates_base]\n","                cold_wals_score_norm = (cold_wals_score - wals_mean) / wals_std\n","                cold_scores = cold_bpr_residual + wals_w * cold_wals_score_norm\n","            else:\n","                cold_scores = cold_bpr_residual\n","\n","            cold_ranked_order = np.argsort(-cold_scores)\n","            cold_ranked = cold_candidates_base[cold_ranked_order]\n","\n","        for cid in tqdm(user_cohort, desc=f\"Eval {name}\"):\n","            pos_set = test_pos[cid]\n","            u_idx = u_enc.get(cid, -1)\n","\n","            if u_idx >= 0:\n","                # ── WARM USER EVAL ──\n","                # 1. WALS candidate generation\n","                scores_wals = wals_gm + wals_ub[u_idx] + wals_ib + wals_uf[u_idx] @ wals_if.T\n","                k_cands = min(N_CANDIDATES, n_items)\n","                top = np.argpartition(-scores_wals, k_cands-1)[:k_cands]\n","                cands = top[np.argsort(-scores_wals[top])].astype(np.int32)\n","\n","                # 2. Filter out training positives\n","                seen = train_pos.get(u_idx, set())\n","                if seen:\n","                    cands = np.array([c for c in cands if c not in seen], dtype=np.int32)\n","                if len(cands) == 0:\n","                    continue\n","\n","                # 3. Compute BPR scores for candidates\n","                residual = bpr_uf[u_idx] @ bpr_if[cands].T + bpr_ib[cands]\n","                bpr_score = softplus(residual_scale) * residual\n","                if use_wals_features:\n","                    wals_score = wals_gm + wals_ub[u_idx] + wals_ib[cands] + wals_uf[u_idx] @ wals_if[cands].T\n","                    wals_score_norm = (wals_score - wals_mean) / wals_std\n","                    scores = bpr_score + wals_w * wals_score_norm\n","                else:\n","                    scores = bpr_score\n","\n","                order = np.argsort(-scores)\n","                ranked = cands[order]\n","            else:\n","                # ── COLD USER EVAL ──\n","                # Cold users have no train positives and all share the same ranked candidates\n","                ranked = cold_ranked\n","\n","            # Compute MAP@10\n","            hits, prec_sum = 0, 0.0\n","            for rank, iid in enumerate(ranked[:TOP_K], 1):\n","                if iid in pos_set:\n","                    hits += 1\n","                    prec_sum += hits / rank\n","            map_scores.append(prec_sum / min(len(pos_set), TOP_K))\n","\n","            # Compute NDCG@10\n","            dcg = sum((1 / np.log2(r + 2)) for r, iid in enumerate(ranked[:TOP_K])\n","                       if iid in pos_set)\n","            idcg = sum(1 / np.log2(r + 2) for r in range(min(len(pos_set), TOP_K)))\n","            ndcg_scores.append(dcg / idcg if idcg > 0 else 0.0)\n","\n","        mean_map = np.mean(map_scores) if map_scores else 0.0\n","        mean_ndcg = np.mean(ndcg_scores) if ndcg_scores else 0.0\n","        print(f\"\\nCohort [{name}] Results:\")\n","        print(f\"  Users evaluated: {len(map_scores):,}\")\n","        print(f\"  MAP@10:          {mean_map:.4f}\")\n","        print(f\"  NDCG@10:         {mean_ndcg:.4f}\")\n","        return mean_map, mean_ndcg\n","\n","    # 6. Run evaluations\n","    print(\"\\n--- Starting Cohort Evaluations ---\")\n","    evaluate_cohort(warm_users_list, \"Warm\")\n","    evaluate_cohort(cold_users_list, \"Cold\")\n","    evaluate_cohort(eval_users, \"All\")\n","\n","if __name__ == \"__main__\":\n","    main()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"928ptQawoeXK","executionInfo":{"status":"ok","timestamp":1781248938646,"user_tz":-330,"elapsed":1076808,"user":{"displayName":"vani","userId":"03423747302954611071"}},"outputId":"a4f33f89-3c5a-41c0-cc63-55cfbc6f8a9a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loading WALS model from /content/drive/Shareddrives/netflixrecommendationsystem/wals_stage1.pkl...\n","  WALS catalog: 287,916 users, 16,560 items\n","Loading BPR model from /content/drive/Shareddrives/netflixrecommendationsystem/bpr_stage3.pkl...\n","Extracting weights to NumPy CPU space for ultra-fast matching...\n","  Scalar parameters: residual_scale=0.9006, wals_w=0.8295, mean=3.322, std=1.353\n","\n","Loading train.parquet to build train positive sets...\n","Hashing training positives...\n","  Mapped positives for 286,961 warm users.\n","\n","Loading test.parquet...\n","Mapping and hashing test positives...\n","  Found 251,450 users in test set with >=1 positive item.\n","\n","Categorizing users into cohorts...\n","  Cohort Warm: 212,166 users\n","  Cohort Cold: 39,284 users\n","  Cohort All:  251,450 users\n","\n","--- Starting Cohort Evaluations ---\n"]},{"output_type":"stream","name":"stderr","text":["Eval Warm: 100%|██████████| 212166/212166 [08:14<00:00, 428.67it/s]\n"]},{"output_type":"stream","name":"stdout","text":["\n","Cohort [Warm] Results:\n","  Users evaluated: 212,166\n","  MAP@10:          0.0521\n","  NDCG@10:         0.1027\n"]},{"output_type":"stream","name":"stderr","text":["Eval Cold: 100%|██████████| 39284/39284 [00:01<00:00, 36258.37it/s]\n"]},{"output_type":"stream","name":"stdout","text":["\n","Cohort [Cold] Results:\n","  Users evaluated: 39,284\n","  MAP@10:          0.1319\n","  NDCG@10:         0.2188\n"]},{"output_type":"stream","name":"stderr","text":["Eval All: 100%|██████████| 251450/251450 [08:25<00:00, 497.76it/s]\n"]},{"output_type":"stream","name":"stdout","text":["\n","Cohort [All] Results:\n","  Users evaluated: 251,450\n","  MAP@10:          0.0646\n","  NDCG@10:         0.1208\n"]}]},{"cell_type":"markdown","source":["# Final submission"],"metadata":{"id":"enyuRgpEWuQ7"}},{"cell_type":"code","source":["#!/usr/bin/env python3\n","\"\"\"\n","generate_final_predictions.py\n","==============================\n","Two independent functions:\n","\n","  1. predict_ratings(m, probe_df)\n","     - WALS dot-product prediction for every (MovieID, CustomerID) pair.\n","       Row order is preserved exactly.\n","     - Output: predicted_ratings.csv  [MovieID, CustomerID, PredictedRating]\n","\n","  2. generate_recommendations(m, probe_df)\n","     - For each unique CustomerID (in probe first-appearance order):\n","         * Take top-N_CANDIDATES=2000 from WALS\n","         * Rerank with BPR (bpr_model.pkl)\n","         * Return top-TOP_K=10 per user\n","     - Output: recommendations.csv  [CustomerID, Rank, MovieID, Score]\n","\n","Colab-safe: no __file__ references.\n","\"\"\"\n","\n","import gc\n","import sys\n","import pickle\n","import collections\n","from pathlib import Path\n","\n","import numpy as np\n","import pandas as pd\n","from tqdm import tqdm\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","#  PATHS  — update before running\n","# ─────────────────────────────────────────────────────────────────────────────\n","ROOT       = Path(\"/content/drive/Shareddrives/netflixrecommendationsystem\")\n","\n","WALS_PATH  = ROOT / \"wals_stage1.pkl\"      # WALS stage-1 checkpoint\n","BPR_PATH   = ROOT / \"bpr_stage3.pkl\"        # BPR reranker checkpoint\n","\n","PROBE_PATH = ROOT / \"dataset\" / \"qualifying.csv\"   # or probe_ratings.parquet\n","TRAIN_PATH = ROOT / \"train.parquet\"        # to filter already-seen items from recs\n","\n","OUT_RATINGS = ROOT / \"predicted_ratings.csv\"\n","OUT_RECS    = ROOT / \"recommendations.csv\"\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","# HYPER-PARAMETERS\n","# ─────────────────────────────────────────────────────────────────────────────\n","N_CANDIDATES   = 2000          # WALS candidates fed into BPR reranker\n","TOP_K          = 10            # final recommendations per user\n","RATING_CLIP    = (1.0, 5.0)   # valid rating range for clipping\n","\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","#  Helpers\n","# ─────────────────────────────────────────────────────────────────────────────\n","def _softplus(x: float) -> float:\n","    \"\"\"Numerically-stable scalar softplus.\"\"\"\n","    return float(np.log1p(np.exp(x)) if x < 20.0 else x)\n","\n","\n","def _read_df(path: Path) -> pd.DataFrame:\n","    \"\"\"\n","    Read parquet or CSV and normalise column names to\n","    [MovieID, CustomerID, Rating].  Rating column is optional.\n","    \"\"\"\n","    if str(path).endswith(\".parquet\"):\n","        df = pd.read_parquet(path)\n","    else:\n","        df = pd.read_csv(path)\n","\n","    rename = {}\n","    for c in df.columns:\n","        cl = c.lower()\n","        if   cl in (\"customerid\", \"userid\",  \"user_id\",  \"customer_id\"): rename[c] = \"CustomerID\"\n","        elif cl in (\"movieid\",    \"itemid\",  \"movie_id\", \"item_id\"):      rename[c] = \"MovieID\"\n","        elif cl in (\"rating\",     \"ratings\"):                             rename[c] = \"Rating\"\n","    df.rename(columns=rename, inplace=True)\n","\n","    df[\"CustomerID\"] = df[\"CustomerID\"].astype(np.int32)\n","    df[\"MovieID\"]    = df[\"MovieID\"].astype(np.int32)\n","    if \"Rating\" in df.columns:\n","        df[\"Rating\"] = df[\"Rating\"].astype(np.float32)\n","    return df\n","\n","\n","def _load_train_pos(path: Path, u_enc: dict, i_enc: dict,\n","                    min_rating: float = 3.5) -> dict:\n","    \"\"\"\n","    Build  uid -> set(iid)  from train.parquet.\n","    Used to filter already-seen items out of recommendations.\n","    Returns empty dict if file is not found (filtering skipped).\n","    \"\"\"\n","    if not path.is_file():\n","        print(f\"    {path} not found — seen-item filtering skipped.\")\n","        return {}\n","\n","    print(f\"   Loading train positives from {path} …\")\n","    df = _read_df(path)\n","    if \"Rating\" in df.columns:\n","        df = df[df[\"Rating\"] >= min_rating]\n","\n","    train_pos = collections.defaultdict(set)\n","    for cid, mid in zip(df[\"CustomerID\"].values, df[\"MovieID\"].values):\n","        uid = u_enc.get(int(cid), -1)\n","        iid = i_enc.get(int(mid), -1)\n","        if uid >= 0 and iid >= 0:\n","            train_pos[uid].add(iid)\n","\n","    del df; gc.collect()\n","    print(f\"   Train positives built for {len(train_pos):,} users.\")\n","    return train_pos\n","\n","\n","def _load_models() -> dict:\n","    \"\"\"\n","    Load WALS + BPR checkpoints.\n","    Extracts all weights into NumPy float32 arrays for fast CPU inference.\n","    \"\"\"\n","    # ── WALS ──────────────────────────────────────────────────────────────────\n","    print(f\"▶ Loading WALS from {WALS_PATH} …\")\n","    with open(WALS_PATH, \"rb\") as f:\n","        wals = pickle.load(f)\n","\n","    u_enc = wals[\"u_enc\"]                              # CustomerID → uid\n","    i_enc = wals[\"i_enc\"]                              # MovieID    → iid\n","    i_dec = {v: k for k, v in i_enc.items()}           # iid → MovieID (for output)\n","\n","    wals_uf = np.asarray(wals[\"user_factors\"], dtype=np.float32)\n","    wals_if = np.asarray(wals[\"item_factors\"],  dtype=np.float32)\n","    wals_ub = np.asarray(wals[\"user_biases\"],   dtype=np.float32)\n","    wals_ib = np.asarray(wals[\"item_biases\"],   dtype=np.float32)\n","    wals_gm = float(wals[\"global_mean\"])\n","    n_items = wals_if.shape[0]\n","\n","    print(f\"   WALS: {len(u_enc):,} users  {n_items:,} items  \"\n","          f\"dim={wals_if.shape[1]}  global_mean={wals_gm:.4f}\")\n","\n","    # ── BPR ───────────────────────────────────────────────────────────────────\n","    print(f\"▶ Loading BPR from {BPR_PATH} …\")\n","    with open(BPR_PATH, \"rb\") as f:\n","        bpr_ckpt = pickle.load(f)\n","\n","    state = bpr_ckpt[\"state_dict\"]\n","\n","    bpr_uf = state[\"user_emb.weight\"].cpu().numpy().astype(np.float32)\n","    bpr_if = state[\"item_emb.weight\"].cpu().numpy().astype(np.float32)\n","    bpr_ib = state[\"item_bias.weight\"].cpu().numpy().squeeze(-1).astype(np.float32)\n","\n","    # scalar parameters — fall back to sensible defaults for older checkpoints\n","    def _s(key, default):\n","        v = state.get(key)\n","        return v.cpu().item() if v is not None else default\n","\n","    residual_scale = _softplus(_s(\"residual_scale\", 0.1))\n","    use_wals_feat  = bpr_ckpt.get(\"use_wals_features\", True)\n","    wals_w         = _softplus(_s(\"wals_w_raw\", 0.5)) if use_wals_feat else 0.0\n","    wals_mean      = _s(\"wals_mean\", 3.322)\n","    wals_std       = _s(\"wals_std\",  1.353)\n","\n","    print(f\"   BPR:  residual_scale={residual_scale:.4f}  \"\n","          f\"wals_w={wals_w:.4f}  use_wals_feat={use_wals_feat}\")\n","\n","    return dict(\n","        u_enc=u_enc, i_enc=i_enc, i_dec=i_dec,\n","        wals_uf=wals_uf, wals_if=wals_if,\n","        wals_ub=wals_ub, wals_ib=wals_ib, wals_gm=wals_gm,\n","        n_items=n_items,\n","        bpr_uf=bpr_uf, bpr_if=bpr_if, bpr_ib=bpr_ib,\n","        residual_scale=residual_scale,\n","        use_wals_feat=use_wals_feat,\n","        wals_w=wals_w, wals_mean=wals_mean, wals_std=wals_std,\n","    )\n","\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","# 1. predict_ratings()\n","# ─────────────────────────────────────────────────────────────────────────────\n","def predict_ratings(m: dict, probe_df: pd.DataFrame) -> pd.DataFrame:\n","    \"\"\"\n","    WALS rating prediction for every (MovieID, CustomerID) row.\n","    Row order is preserved exactly — identical to the input probe_df.\n","\n","    Warm user  + known item  →  gm + user_bias + item_bias + u·v\n","    Cold user  + known item  →  gm + item_bias\n","    Unknown item             →  gm  (global fallback)\n","\n","    Clipped to RATING_CLIP = [1.0, 5.0].\n","    \"\"\"\n","    print(\"\\n═══ 1 / 2   Rating Prediction (WALS) ═══\")\n","\n","    u_enc, i_enc     = m[\"u_enc\"], m[\"i_enc\"]\n","    wals_uf, wals_if = m[\"wals_uf\"], m[\"wals_if\"]\n","    wals_ub, wals_ib = m[\"wals_ub\"], m[\"wals_ib\"]\n","    wals_gm          = m[\"wals_gm\"]\n","\n","    cust_ids  = probe_df[\"CustomerID\"].values.astype(np.int32)\n","    movie_ids = probe_df[\"MovieID\"].values.astype(np.int32)\n","    n         = len(probe_df)\n","\n","    u_idx = np.array([u_enc.get(int(c), -1) for c in cust_ids],  dtype=np.int32)\n","    i_idx = np.array([i_enc.get(int(v), -1) for v in movie_ids], dtype=np.int32)\n","\n","    preds = np.full(n, wals_gm, dtype=np.float32)\n","\n","    # Warm: known user AND item\n","    warm = (u_idx >= 0) & (i_idx >= 0)\n","    if warm.any():\n","        uw, iw = u_idx[warm], i_idx[warm]\n","        preds[warm] = (\n","            wals_gm\n","            + wals_ub[uw]\n","            + wals_ib[iw]\n","            + np.einsum(\"nd,nd->n\", wals_uf[uw], wals_if[iw])\n","        )\n","\n","    # Cold: unknown user, known item\n","    cold = (u_idx < 0) & (i_idx >= 0)\n","    if cold.any():\n","        preds[cold] = wals_gm + wals_ib[i_idx[cold]]\n","\n","    preds = np.clip(preds, *RATING_CLIP)\n","\n","    result = pd.DataFrame({\n","        \"MovieID\"         : movie_ids.tolist(),\n","        \"CustomerID\"      : cust_ids.tolist(),\n","        \"PredictedRating\" : preds.tolist(),\n","    })\n","\n","    print(f\"   Rows predicted : {n:,}\")\n","    print(f\"   Warm rows      : {warm.sum():,}  |  Cold rows: {cold.sum():,}\")\n","\n","    # RMSE only if actuals are present (probe set, not qualifying)\n","    if \"Rating\" in probe_df.columns:\n","        actual = probe_df[\"Rating\"].values.astype(np.float32)\n","        known  = warm | cold\n","        rmse   = np.sqrt(np.mean((actual[known] - preds[known]) ** 2))\n","        print(f\"   WALS RMSE (clipped [1-5]) = {rmse:.4f}\")\n","\n","    return result\n","\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","# 2. generate_recommendations()\n","# ─────────────────────────────────────────────────────────────────────────────\n","def generate_recommendations(m: dict, probe_df: pd.DataFrame,\n","                              train_pos: dict | None = None) -> pd.DataFrame:\n","    \"\"\"\n","    For each unique CustomerID in probe_df (first-appearance order):\n","      1. WALS top-2000 candidate retrieval\n","      2. Filter out training positives (warm users only)\n","      3. BPR rerank → top-10\n","\n","    Output columns: [CustomerID, Rank, MovieID, Score]\n","      - CustomerID order = first appearance in probe_df\n","      - Rank 1 = best recommendation\n","      - MovieID = original Netflix MovieID\n","    \"\"\"\n","    print(\"\\n═══ 2 / 2   Recommendation Generation (BPR reranker) ═══\")\n","\n","    u_enc, i_enc, i_dec = m[\"u_enc\"], m[\"i_enc\"], m[\"i_dec\"]\n","    wals_uf, wals_if    = m[\"wals_uf\"], m[\"wals_if\"]\n","    wals_ub, wals_ib    = m[\"wals_ub\"], m[\"wals_ib\"]\n","    wals_gm             = m[\"wals_gm\"]\n","    n_items             = m[\"n_items\"]\n","    bpr_uf, bpr_if, bpr_ib = m[\"bpr_uf\"], m[\"bpr_if\"], m[\"bpr_ib\"]\n","    rs                  = m[\"residual_scale\"]\n","    use_wals_feat       = m[\"use_wals_feat\"]\n","    wals_w              = m[\"wals_w\"]\n","    wals_mean           = m[\"wals_mean\"]\n","    wals_std            = m[\"wals_std\"]\n","    k_cand              = min(N_CANDIDATES, n_items)   # 2000\n","\n","    if train_pos is None:\n","        train_pos = {}\n","\n","    # ── CustomerIDs in first-appearance order ──────────────────────────────\n","    first_seen = {}\n","    for cid in probe_df[\"CustomerID\"].values:\n","        cid = int(cid)\n","        if cid not in first_seen:\n","            first_seen[cid] = len(first_seen)\n","    ordered_customers = sorted(first_seen, key=lambda c: first_seen[c])\n","    print(f\"   Unique customers : {len(ordered_customers):,}\")\n","\n","    # ── Pre-compute cold-user ranked list (shared; done once) ─────────────\n","    print(\"   Pre-computing cold-user fallback candidates …\")\n","    cold_wals_s = wals_gm + wals_ib\n","    cold_top    = np.argpartition(-cold_wals_s, k_cand - 1)[:k_cand]\n","    cold_cands  = cold_top[np.argsort(-cold_wals_s[cold_top])].astype(np.int32)\n","    cold_bpr_s  = rs * bpr_ib[cold_cands]\n","    if use_wals_feat:\n","        cold_bpr_s += wals_w * ((wals_gm + wals_ib[cold_cands] - wals_mean) / wals_std)\n","    cold_order         = np.argsort(-cold_bpr_s)\n","    cold_ranked_iids   = cold_cands[cold_order[:TOP_K]]\n","    cold_ranked_scores = cold_bpr_s[cold_order[:TOP_K]]\n","\n","    # ── Per-user loop ──────────────────────────────────────────────────────\n","    rows = []\n","\n","    for cid in tqdm(ordered_customers, desc=\"Recommending\", unit=\"user\"):\n","        uid = u_enc.get(cid, -1)\n","\n","        if uid >= 0:\n","            # ── WARM USER ────────────────────────────────────────────────\n","            # 1. WALS top-2000 candidates\n","            wals_s = (wals_gm + wals_ub[uid] + wals_ib\n","                      + wals_uf[uid] @ wals_if.T)\n","            top    = np.argpartition(-wals_s, k_cand - 1)[:k_cand]\n","            cands  = top[np.argsort(-wals_s[top])].astype(np.int32)\n","\n","            # 2. Filter already-seen training items\n","            seen_iids = train_pos.get(uid, set())\n","            if seen_iids:\n","                cands = np.array([c for c in cands if c not in seen_iids],\n","                                 dtype=np.int32)\n","            if cands.size == 0:\n","                continue\n","\n","            # 3. BPR rerank\n","            residual  = bpr_uf[uid] @ bpr_if[cands].T + bpr_ib[cands]\n","            bpr_score = rs * residual\n","            if use_wals_feat:\n","                w_s = (wals_gm + wals_ub[uid] + wals_ib[cands]\n","                       + wals_uf[uid] @ wals_if[cands].T)\n","                bpr_score += wals_w * ((w_s - wals_mean) / wals_std)\n","\n","            order        = np.argsort(-bpr_score)\n","            top_k_iids   = cands[order[:TOP_K]]\n","            top_k_scores = bpr_score[order[:TOP_K]]\n","\n","        else:\n","            # ── COLD USER ────────────────────────────────────────────────\n","            top_k_iids   = cold_ranked_iids\n","            top_k_scores = cold_ranked_scores\n","\n","        for rank, (iid, score) in enumerate(zip(top_k_iids, top_k_scores), start=1):\n","            rows.append({\n","                \"CustomerID\": cid,\n","                \"Rank\"      : rank,\n","                \"MovieID\"   : i_dec.get(int(iid), -1),\n","                \"Score\"     : float(score),\n","            })\n","\n","    rec_df = pd.DataFrame(rows, columns=[\"CustomerID\", \"Rank\", \"MovieID\", \"Score\"])\n","    print(f\"   Rows generated : {len(rec_df):,}  \"\n","          f\"({rec_df['CustomerID'].nunique():,} users × up to {TOP_K} items)\")\n","    return rec_df\n","\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","# 🏃  main\n","# ─────────────────────────────────────────────────────────────────────────────\n","def main():\n","    for p, label in [(WALS_PATH, \"WALS\"), (BPR_PATH, \"BPR\"), (PROBE_PATH, \"Probe\")]:\n","        if not p.is_file():\n","            sys.exit(f\" {label} file not found at {p}\")\n","\n","    m = _load_models()\n","\n","    print(f\"\\n▶ Loading probe/qualifying data from {PROBE_PATH} …\")\n","    probe_df = _read_df(PROBE_PATH)\n","    print(f\"   {len(probe_df):,} rows  |  \"\n","          f\"{probe_df['CustomerID'].nunique():,} unique customers  |  \"\n","          f\"{probe_df['MovieID'].nunique():,} unique movies\")\n","\n","    # load training positives for seen-item filtering\n","    train_pos = _load_train_pos(TRAIN_PATH, m[\"u_enc\"], m[\"i_enc\"])\n","\n","    # ── 1. Rating predictions ──────────────────────────────────────────────\n","    ratings_df = predict_ratings(m, probe_df)\n","    ratings_df.to_csv(OUT_RATINGS, index=False)\n","    print(f\"\\n  Saved rating predictions → {OUT_RATINGS}\")\n","    print(ratings_df.head(10).to_string(index=False))\n","\n","    # ── 2. Recommendations ────────────────────────────────────────────────\n","    rec_df = generate_recommendations(m, probe_df, train_pos=train_pos)\n","    rec_df.to_csv(OUT_RECS, index=False)\n","    print(f\"\\n Saved recommendations → {OUT_RECS}\")\n","    print(rec_df.head(30).to_string(index=False))\n","\n","    print(\"\\n╔══════════════════════════════════════════════╗\")\n","    print(\"║             Output Summary                  ║\")\n","    print(\"╠══════════════════════════════════════════════╣\")\n","    print(f\"║  predicted_ratings.csv   {len(ratings_df):>12,} rows      ║\")\n","    print(f\"║  recommendations.csv     {len(rec_df):>12,} rows      ║\")\n","    print(f\"║  Unique customers (recs) {rec_df['CustomerID'].nunique():>12,}           ║\")\n","    print(\"╚══════════════════════════════════════════════╝\")\n","\n","\n","if __name__ == \"__main__\":\n","    main()\n"],"metadata":{"id":"A3CwAiW0W72v","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781255850527,"user_tz":-330,"elapsed":132525,"user":{"displayName":"MANGALAPALLY SAI VASHISTA 24117071","userId":"18399268862536660880"}},"outputId":"56ecb3c1-1593-4f38-bf3e-ce68bbb8a997"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["▶ Loading WALS from /content/drive/Shareddrives/netflixrecommendationsystem/wals_stage1.pkl …\n","   WALS: 287,916 users  16,560 items  dim=128  global_mean=3.5792\n","▶ Loading BPR from /content/drive/Shareddrives/netflixrecommendationsystem/bpr_stage3.pkl …\n","   BPR:  residual_scale=0.9006  wals_w=0.8295  use_wals_feat=True\n","\n","▶ Loading probe/qualifying data from /content/drive/Shareddrives/netflixrecommendationsystem/dataset/qualifying.csv …\n","   2,817,131 rows  |  478,615 unique customers  |  17,470 unique movies\n","    /content/drive/Shareddrives/netflixrecommendationsystem/train.parquet not found — seen-item filtering skipped.\n","\n","═══ 1 / 2   Rating Prediction (WALS) ═══\n","   Rows predicted : 2,817,131\n","   Warm rows      : 287,557  |  Cold rows: 2,361,942\n","\n","  Saved rating predictions → /content/drive/Shareddrives/netflixrecommendationsystem/predicted_ratings.csv\n"," MovieID  CustomerID  PredictedRating\n","       1     1046323         3.730515\n","       1     1080030         3.730515\n","       1     1830096         3.730515\n","       1      368059         3.730515\n","       1      802003         3.730515\n","       1      513509         3.730515\n","       1     1086137         3.730515\n","       1      428698         3.730515\n","       1      515850         3.730515\n","       1      131974         4.003650\n","\n","═══ 2 / 2   Recommendation Generation (BPR reranker) ═══\n","   Unique customers : 478,615\n","   Pre-computing cold-user fallback candidates …\n"]},{"output_type":"stream","name":"stderr","text":["Recommending: 100%|██████████| 478615/478615 [01:28<00:00, 5390.47user/s]\n"]},{"output_type":"stream","name":"stdout","text":["   Rows generated : 4,786,150  (478,615 users × up to 10 items)\n","\n"," Saved recommendations → /content/drive/Shareddrives/netflixrecommendationsystem/recommendations.csv\n"," CustomerID  Rank  MovieID    Score\n","    1046323     1    13428 1.793229\n","    1046323     2    10850 1.782088\n","    1046323     3    13723 1.735306\n","    1046323     4     3739 1.722264\n","    1046323     5     2307 1.708658\n","    1046323     6     7944 1.652111\n","    1046323     7    15245 1.645791\n","    1046323     8     1115 1.642755\n","    1046323     9    12859 1.638482\n","    1046323    10    10307 1.637236\n","    1080030     1    13428 1.793229\n","    1080030     2    10850 1.782088\n","    1080030     3    13723 1.735306\n","    1080030     4     3739 1.722264\n","    1080030     5     2307 1.708658\n","    1080030     6     7944 1.652111\n","    1080030     7    15245 1.645791\n","    1080030     8     1115 1.642755\n","    1080030     9    12859 1.638482\n","    1080030    10    10307 1.637236\n","    1830096     1    13428 1.793229\n","    1830096     2    10850 1.782088\n","    1830096     3    13723 1.735306\n","    1830096     4     3739 1.722264\n","    1830096     5     2307 1.708658\n","    1830096     6     7944 1.652111\n","    1830096     7    15245 1.645791\n","    1830096     8     1115 1.642755\n","    1830096     9    12859 1.638482\n","    1830096    10    10307 1.637236\n","\n","╔══════════════════════════════════════════════╗\n","║             Output Summary                  ║\n","╠══════════════════════════════════════════════╣\n","║  predicted_ratings.csv      2,817,131 rows      ║\n","║  recommendations.csv        4,786,150 rows      ║\n","║  Unique customers (recs)      478,615           ║\n","╚══════════════════════════════════════════════╝\n"]}]},{"cell_type":"code","source":["#!/usr/bin/env python3\n","\"\"\"\n","explain_recommendations.py\n","===========================\n","Given a CustomerID, generates the user's top-10 movie recommendations\n","with full explanations for why each movie was recommended.\n","\n","Colab usage (paste into a cell and run):\n","    CUSTOMER_ID = 79          # ← change this to any CustomerID\n","    movies        = load_movies(MOVIES_PATH)\n","    m             = load_models()\n","    train_history = load_train_history(TRAIN_PATH, m[\"u_enc\"], m[\"i_enc\"])\n","    run(CUSTOMER_ID, m, movies, train_history)\n","\n","Terminal usage:\n","    python3 explain_recommendations_v2.py\n","    # Edit CUSTOMER_ID below to change user\n","\"\"\"\n","\n","import pickle\n","import collections\n","from pathlib import Path\n","\n","import numpy as np\n","import pandas as pd\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","# ⚙️  PATHS — update if running in Colab\n","# ─────────────────────────────────────────────────────────────────────────────\n","# ─────────────────────────────────────────────────────────────────────────────\n","# ⚙️  CHANGE THESE to match your environment\n","# ─────────────────────────────────────────────────────────────────────────────\n","\n","# ── Colab (uncomment and use this block): ──\n","ROOT        = Path(\"/content/drive/Shareddrives/netflixrecommendationsystem\")\n","WALS_PATH   = ROOT / \"wals_stage1.pkl\"\n","BPR_PATH    = ROOT / \"bpr_stage3.pkl\"    # ← your trained BPR checkpoint\n","TRAIN_PATH  = ROOT / \"dataset\" / \"train.parquet\"\n","MOVIES_PATH = ROOT / \"dataset\" / \"movie_titles.csv\"\n","\n","# ── Local Mac (comment out the block above and use this instead): ──\n","# ROOT        = Path(\"/Users/vani/Downloads/archive\")\n","# WALS_PATH   = ROOT / \"wals_stage1.pkl\"\n","# BPR_PATH    = ROOT / \"bpr_stage2.pkl\"\n","# TRAIN_PATH  = ROOT / \"train.parquet\"\n","# MOVIES_PATH = ROOT / \"movie_titles.csv\"\n","# ─────────────────────────────────────────────────────────────────────────────\n","CUSTOMER_ID  = 79       # warm user example  (has 758 training ratings)\n","# CUSTOMER_ID = 1046323  # cold user example  (never seen in training)\n","\n","# ── Other hyper-parameters (usually no need to change) ──\n","N_CANDIDATES = 2000\n","TOP_K        = 10\n","RELEVANCE   = 3.5   # rating threshold to count as \"liked\"\n","\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","#  Helpers\n","# ─────────────────────────────────────────────────────────────────────────────\n","def _softplus(x: float) -> float:\n","    return float(np.log1p(np.exp(x)) if x < 20.0 else x)\n","\n","\n","def load_movies(path: Path) -> pd.DataFrame:\n","    \"\"\"Load movie_titles.csv → MovieID, Year, Title.\"\"\"\n","    movies = pd.read_csv(\n","        path, encoding=\"latin-1\", header=None,\n","        names=[\"MovieID\", \"Year\", \"Title\"], on_bad_lines=\"skip\"\n","    )\n","    movies[\"Year\"] = pd.to_numeric(movies[\"Year\"], errors=\"coerce\")\n","    return movies\n","\n","\n","def load_models() -> dict:\n","    \"\"\"Load WALS + BPR checkpoints and extract NumPy arrays.\"\"\"\n","    print(f\"Loading WALS from {WALS_PATH} …\")\n","    with open(WALS_PATH, \"rb\") as f:\n","        wals = pickle.load(f)\n","\n","    print(f\"Loading BPR  from {BPR_PATH} …\")\n","    with open(BPR_PATH, \"rb\") as f:\n","        bpr_ckpt = pickle.load(f)\n","\n","    state = bpr_ckpt[\"state_dict\"]\n","\n","    def _s(key, default):\n","        v = state.get(key)\n","        return v.cpu().item() if v is not None else default\n","\n","    u_enc = wals[\"u_enc\"]\n","    i_enc = wals[\"i_enc\"]\n","    i_dec = {v: k for k, v in i_enc.items()}\n","\n","    wals_uf = np.asarray(wals[\"user_factors\"], dtype=np.float32)\n","    wals_if = np.asarray(wals[\"item_factors\"],  dtype=np.float32)\n","    wals_ub = np.asarray(wals[\"user_biases\"],   dtype=np.float32)\n","    wals_ib = np.asarray(wals[\"item_biases\"],   dtype=np.float32)\n","    wals_gm = float(wals[\"global_mean\"])\n","\n","    bpr_uf = state[\"user_emb.weight\"].cpu().numpy().astype(np.float32)\n","    bpr_if = state[\"item_emb.weight\"].cpu().numpy().astype(np.float32)\n","    bpr_ib = state[\"item_bias.weight\"].cpu().numpy().squeeze(-1).astype(np.float32)\n","\n","    residual_scale = _softplus(_s(\"residual_scale\", 0.1))\n","    use_wals_feat  = bpr_ckpt.get(\"use_wals_features\", True)\n","    wals_w         = _softplus(_s(\"wals_w_raw\", 0.5)) if use_wals_feat else 0.0\n","    wals_mean      = _s(\"wals_mean\", 3.322)\n","    wals_std       = _s(\"wals_std\",  1.353)\n","\n","    print(f\"  {len(u_enc):,} users  {wals_if.shape[0]:,} items  \"\n","          f\"dim={wals_if.shape[1]}\")\n","    print(f\"  residual_scale={residual_scale:.3f}  wals_w={wals_w:.3f}\")\n","\n","    return dict(\n","        u_enc=u_enc, i_enc=i_enc, i_dec=i_dec,\n","        wals_uf=wals_uf, wals_if=wals_if,\n","        wals_ub=wals_ub, wals_ib=wals_ib, wals_gm=wals_gm,\n","        bpr_uf=bpr_uf, bpr_if=bpr_if, bpr_ib=bpr_ib,\n","        residual_scale=residual_scale,\n","        use_wals_feat=use_wals_feat,\n","        wals_w=wals_w, wals_mean=wals_mean, wals_std=wals_std,\n","        n_items=wals_if.shape[0],\n","    )\n","\n","\n","def load_train_history(path: Path, u_enc: dict, i_enc: dict) -> dict:\n","    \"\"\"\n","    Load train.parquet and return:\n","      uid → list of (iid, rating, movie_id) sorted by rating desc\n","    \"\"\"\n","    print(f\"Loading training history from {path} …\")\n","    df = pd.read_parquet(path, columns=[\"CustomerID\", \"MovieID\", \"Rating\"])\n","    df[\"CustomerID\"] = df[\"CustomerID\"].astype(np.int32)\n","    df[\"MovieID\"]    = df[\"MovieID\"].astype(np.int32)\n","    df[\"Rating\"]     = df[\"Rating\"].astype(np.float32)\n","\n","    history = collections.defaultdict(list)\n","    for cid, mid, rat in zip(df[\"CustomerID\"].values,\n","                              df[\"MovieID\"].values,\n","                              df[\"Rating\"].values):\n","        uid = u_enc.get(int(cid), -1)\n","        iid = i_enc.get(int(mid), -1)\n","        if uid >= 0:\n","            history[uid].append((iid, float(rat), int(mid)))\n","\n","    # sort each user's history by rating desc\n","    for uid in history:\n","        history[uid].sort(key=lambda x: -x[1])\n","\n","    print(f\"  History loaded for {len(history):,} users.\")\n","    return history\n","\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","#   Explanation builder\n","# ─────────────────────────────────────────────────────────────────────────────\n","def _decade_label(year) -> str:\n","    if pd.isna(year):\n","        return \"unknown era\"\n","    decade = int(year) // 10 * 10\n","    return f\"{decade}s\"\n","\n","\n","def _build_user_profile(uid: int, history: dict, movies: pd.DataFrame) -> dict:\n","    \"\"\"\n","    Summarise a warm user's taste from their training history.\n","    Returns a dict with:\n","      top_liked      – list of (movie_title, rating, year) for rating >= RELEVANCE\n","      liked_decades  – Counter of decades the user liked\n","      liked_iids     – set of iids already rated (for filtering recs)\n","    \"\"\"\n","    records  = history.get(uid, [])\n","    liked    = [(iid, rat, mid) for iid, rat, mid in records if rat >= RELEVANCE]\n","    liked_iids = {r[0] for r in records}   # all seen, not just liked\n","\n","    top_liked = []\n","    decade_counts = collections.Counter()\n","    for iid, rat, mid in liked:\n","        row = movies[movies[\"MovieID\"] == mid]\n","        if len(row) > 0:\n","            title = row[\"Title\"].values[0]\n","            year  = row[\"Year\"].values[0]\n","            top_liked.append((title, rat, year))\n","            dec = _decade_label(year)\n","            decade_counts[dec] += 1\n","\n","    return {\n","        \"top_liked\"    : top_liked,       # (title, rating, year)\n","        \"liked_decades\": decade_counts,\n","        \"liked_iids\"   : liked_iids,\n","        \"n_rated\"      : len(records),\n","        \"n_liked\"      : len(liked),\n","    }\n","\n","\n","def _score_breakdown(uid: int, iid: int, m: dict) -> dict:\n","    \"\"\"\n","    Return the decomposed scores for a (uid, iid) pair so we can\n","    explain *why* this item was scored highly.\n","    \"\"\"\n","    wals_gm  = m[\"wals_gm\"]\n","    wals_ub  = m[\"wals_ub\"]\n","    wals_ib  = m[\"wals_ib\"]\n","    wals_uf  = m[\"wals_uf\"]\n","    wals_if  = m[\"wals_if\"]\n","    bpr_uf   = m[\"bpr_uf\"]\n","    bpr_if   = m[\"bpr_if\"]\n","    bpr_ib   = m[\"bpr_ib\"]\n","    rs       = m[\"residual_scale\"]\n","    wals_w   = m[\"wals_w\"]\n","    wals_mean = m[\"wals_mean\"]\n","    wals_std  = m[\"wals_std\"]\n","\n","    item_bias_raw = float(wals_ib[iid])   # item popularity in WALS\n","\n","    if uid >= 0:\n","        wals_score = float(\n","            wals_gm + wals_ub[uid] + wals_ib[iid]\n","            + wals_uf[uid] @ wals_if[iid]\n","        )\n","        bpr_residual = float(\n","            rs * (bpr_uf[uid] @ bpr_if[iid] + bpr_ib[iid])\n","        )\n","    else:\n","        wals_score   = float(wals_gm + wals_ib[iid])\n","        bpr_residual = float(rs * bpr_ib[iid])\n","\n","    wals_norm = (wals_score - wals_mean) / wals_std\n","    total     = bpr_residual + wals_w * wals_norm\n","\n","    return {\n","        \"total\"        : total,\n","        \"wals_score\"   : wals_score,\n","        \"bpr_residual\" : bpr_residual,\n","        \"item_bias\"    : item_bias_raw,\n","    }\n","\n","\n","def _build_explanation(rank: int, movie_row: pd.Series, breakdown: dict,\n","                        profile: dict, is_cold: bool) -> str:\n","    \"\"\"\n","    Produce a 1–2 sentence natural-language explanation for why\n","    this movie was recommended at this rank.\n","    \"\"\"\n","    title = movie_row[\"Title\"]\n","    year  = movie_row[\"Year\"]\n","    dec   = _decade_label(year)\n","\n","    wals_pred  = breakdown[\"wals_score\"]\n","    bpr_res    = breakdown[\"bpr_residual\"]\n","    item_bias  = breakdown[\"item_bias\"]\n","    total      = breakdown[\"total\"]\n","\n","    # --- dominant signal decision ---\n","    abs_wals = abs(wals_pred - 3.579)   # deviation from global mean\n","    abs_bpr  = abs(bpr_res)\n","\n","    if is_cold:\n","        # cold user — popularity-only explanation\n","        pop_word = \"very popular\" if item_bias > 0.2 else \\\n","                   \"well-liked\"   if item_bias > 0    else \"niche\"\n","        return (\n","            f\"Cold-start recommendation: no viewing history is available \"\n","            f\"for this user. '{title}' is {pop_word} across the Netflix catalog \"\n","            f\"(item popularity score = {item_bias:+.3f}) and appeared in the \"\n","            f\"globally top-rated titles.\"\n","        )\n","\n","    # warm user: build personalised explanation\n","    parts = []\n","\n","    # 1) era match\n","    liked_decades = profile[\"liked_decades\"]\n","    if liked_decades and dec in liked_decades:\n","        top_dec = liked_decades.most_common(1)[0][0]\n","        if dec == top_dec:\n","            parts.append(f\"it's from the {dec}, your most-enjoyed era\")\n","        else:\n","            parts.append(f\"it's from the {dec}, a decade you've enjoyed\")\n","\n","    # 2) WALS predicted rating\n","    if wals_pred >= 4.2:\n","        parts.append(f\"WALS predicts you'd rate it ≈{wals_pred:.1f}/5 \")\n","    elif wals_pred >= 3.8:\n","        parts.append(f\"WALS predicts you'd rate it ≈{wals_pred:.1f}/5 \")\n","\n","    # 3) BPR residual — positive residual means BPR \"boosted\" this item\n","    if bpr_res > 0.05:\n","        parts.append(\n","            f\"the BPR ranker boosted it (+{bpr_res:.3f}) above the WALS baseline, \"\n","            f\"suggesting it fits your taste beyond raw rating prediction\"\n","        )\n","    elif bpr_res < -0.05:\n","        parts.append(\n","            f\"despite a slight BPR discount ({bpr_res:.3f}), WALS strongly \"\n","            f\"predicts you'd enjoy it\"\n","        )\n","\n","    # 4) item popularity\n","    if item_bias > 0.3:\n","        parts.append(\"it's one of the catalog's most-loved titles overall\")\n","    elif item_bias < -0.2:\n","        parts.append(\"it's a hidden gem (below-average rating volume) that matches your unique taste\")\n","\n","    # 5) liked movies era similarity\n","    top_liked = profile[\"top_liked\"][:5]\n","    similar = [t for t, r, y in top_liked if not pd.isna(y) and abs(y - year) <= 5]\n","    if similar:\n","        parts.append(\n","            f\"you gave 5★ to '{similar[0]}' \"\n","            f\"({'same year' if year == [y for _t, _r, y in top_liked if _t == similar[0]][0] else 'similar era'})\"\n","        )\n","\n","    if not parts:\n","        parts.append(f\"strong overall score ({total:.3f}) from both WALS and BPR signals\")\n","\n","    explanation = f\"Recommended because \" + \"; and \".join(parts[:3]) + \".\"\n","    return explanation\n","\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","# main recommendation + explanation function\n","# ─────────────────────────────────────────────────────────────────────────────\n","def explain_for_customer(customer_id: int, m: dict,\n","                         movies: pd.DataFrame,\n","                         train_history: dict) -> pd.DataFrame:\n","    \"\"\"\n","    Generate top-10 movie recommendations for `customer_id` with explanations.\n","\n","    Parameters\n","    ----------\n","    customer_id   : int  — Netflix CustomerID (original, not internal index)\n","    m             : dict — loaded model dict from load_models()\n","    movies        : pd.DataFrame — movie titles table\n","    train_history : dict — uid → list[(iid, rating, movie_id)] from load_train_history()\n","\n","    Returns\n","    -------\n","    pd.DataFrame with columns [Rank, MovieID, Title, Year, PredictedRating, BPRScore, Explanation]\n","    \"\"\"\n","    u_enc     = m[\"u_enc\"]\n","    i_enc     = m[\"i_enc\"]\n","    i_dec     = m[\"i_dec\"]\n","    wals_uf   = m[\"wals_uf\"]\n","    wals_if   = m[\"wals_if\"]\n","    wals_ub   = m[\"wals_ub\"]\n","    wals_ib   = m[\"wals_ib\"]\n","    wals_gm   = m[\"wals_gm\"]\n","    n_items   = m[\"n_items\"]\n","    bpr_uf    = m[\"bpr_uf\"]\n","    bpr_if    = m[\"bpr_if\"]\n","    bpr_ib    = m[\"bpr_ib\"]\n","    rs        = m[\"residual_scale\"]\n","    use_wf    = m[\"use_wals_feat\"]\n","    wals_w    = m[\"wals_w\"]\n","    wals_mean = m[\"wals_mean\"]\n","    wals_std  = m[\"wals_std\"]\n","    k_cand    = min(N_CANDIDATES, n_items)\n","\n","    uid     = u_enc.get(customer_id, -1)\n","    is_cold = uid < 0\n","\n","    # ── User taste profile (warm only) ────────────────────────────────────\n","    profile = _build_user_profile(uid, train_history, movies) if not is_cold else {}\n","    seen_iids = profile.get(\"liked_iids\", set())\n","\n","    # ── WALS Rating Prediction for all items ──────────────────────────────\n","    if not is_cold:\n","        wals_scores_all = (wals_gm + wals_ub[uid] + wals_ib\n","                           + wals_uf[uid] @ wals_if.T)  # (n_items,)\n","    else:\n","        wals_scores_all = wals_gm + wals_ib               # item-bias only\n","\n","    # ── Retrieve top-2000 WALS candidates ─────────────────────────────────\n","    top_idx   = np.argpartition(-wals_scores_all, k_cand - 1)[:k_cand]\n","    cands     = top_idx[np.argsort(-wals_scores_all[top_idx])].astype(np.int32)\n","\n","    # ── Filter seen training items (warm users only) ───────────────────────\n","    if seen_iids:\n","        cands = np.array([c for c in cands if c not in seen_iids], dtype=np.int32)\n","\n","    # ── BPR reranking ─────────────────────────────────────────────────────\n","    if not is_cold:\n","        residual  = bpr_uf[uid] @ bpr_if[cands].T + bpr_ib[cands]\n","        bpr_score = rs * residual\n","        if use_wf:\n","            w_s = (wals_gm + wals_ub[uid] + wals_ib[cands]\n","                   + wals_uf[uid] @ wals_if[cands].T)\n","            bpr_score += wals_w * ((w_s - wals_mean) / wals_std)\n","    else:\n","        bpr_score = rs * bpr_ib[cands]\n","        if use_wf:\n","            bpr_score += wals_w * ((wals_gm + wals_ib[cands] - wals_mean) / wals_std)\n","\n","    order    = np.argsort(-bpr_score)\n","    top_iids = cands[order[:TOP_K]]\n","\n","    # ── Build output ──────────────────────────────────────────────────────\n","    rows = []\n","    for rank, iid in enumerate(top_iids, start=1):\n","        movie_id   = i_dec.get(int(iid), -1)\n","        movie_row  = movies[movies[\"MovieID\"] == movie_id]\n","\n","        if len(movie_row) == 0:\n","            title, year = \"Unknown Title\", float(\"nan\")\n","            movie_row_s = pd.Series({\"Title\": title, \"Year\": year, \"MovieID\": movie_id})\n","        else:\n","            movie_row_s = movie_row.iloc[0]\n","            title = movie_row_s[\"Title\"]\n","            year  = movie_row_s[\"Year\"]\n","\n","        # WALS predicted rating for this item (clipped to [1,5])\n","        wals_pred = float(np.clip(wals_scores_all[iid], 1.0, 5.0))\n","\n","        # full score breakdown for explanation\n","        breakdown = _score_breakdown(uid, iid, m)\n","\n","        # explanation\n","        explanation = _build_explanation(rank, movie_row_s, breakdown, profile, is_cold)\n","\n","        rows.append({\n","            \"Rank\"           : rank,\n","            \"MovieID\"        : movie_id,\n","            \"Title\"          : title,\n","            \"Year\"           : int(year) if not pd.isna(year) else \"N/A\",\n","            \"PredictedRating\": round(wals_pred, 2),\n","            \"BPRScore\"       : round(float(bpr_score[order[rank - 1]]), 4),\n","            \"Explanation\"    : explanation,\n","        })\n","\n","    return pd.DataFrame(rows)\n","\n","\n","def print_recommendations(df: pd.DataFrame, customer_id: int,\n","                          profile: dict, is_cold: bool):\n","    \"\"\"Pretty-print the recommendation table with explanations.\"\"\"\n","    sep = \"═\" * 72\n","\n","    print(f\"\\n{sep}\")\n","    print(f\"  🎬 Netflix Recommendations for CustomerID: {customer_id}\")\n","    print(sep)\