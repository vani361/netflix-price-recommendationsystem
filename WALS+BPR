lay_data","data":{"text/plain":["Epoch 20/20 Users:   0%|          | 0/287916 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"a84e1eb5da9c4cef9c2ecf4513f7a9ff"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["Epoch 20/20 Items:   0%|          | 0/16560 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"c12ee05a7e154ac19c0d07b16e7ba423"}},"metadata":{}},{"output_type":"stream","name":"stdout","text":["   Epoch 20/20 finished in 8.0s\n","\n","Evaluating RMSE (chunked)...\n"]},{"output_type":"display_data","data":{"text/plain":["RMSE:   0%|          | 0/10 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"40e2444c44ae42f58913443635e67ea6"}},"metadata":{}},{"output_type":"stream","name":"stdout","text":["   RMSE: 2.8580  (n=11,381,446)\n","\n","Evaluating MAP@10...\n"]},{"output_type":"display_data","data":{"text/plain":["MAP:   0%|          | 0/5000 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"3e602f3783554d05b307c94e5312b940"}},"metadata":{}},{"output_type":"stream","name":"stdout","text":["   MAP@10: 0.0159  (5,000 users)\n","\n","==================================================\n","  RMSE   : 2.8580\n","  MAP@10  : 0.0159\n","==================================================\n","Saving PyTorch ALS model and encoders to /content/drive/Shareddrives/netflixrecommendationsystem/implicit_als_model.pkl...\n","Model saved successfully!\n"]}]},{"cell_type":"code","source":["#!/usr/bin/env python3\n","\"\"\"\n","Netflix ALS (Alternating Least Squares) — PyTorch MPS GPU Implementation\n","========================================================================\n","Because the `implicit` library only supports NVIDIA CUDA for GPU acceleration,\n","this script implements a highly optimized, fully vectorized Alternating Least Squares\n","(ALS) solver in PyTorch. It leverages Apple Silicon Metal (MPS) GPU acceleration\n","to train the model on your Mac's GPU.\n","\"\"\"\n","\n","import gc\n","import os\n","import time\n","import pickle\n","import numpy as np\n","import pandas as pd\n","import torch\n","from tqdm.auto import tqdm\n","\n","# ── CONFIG ────────────────────────────────────────────────────────────────────\n","FACTORS          = 128\n","REGULARIZATION   = 0.01\n","ITERATIONS       = 20       # PyTorch GPU runs fast, 20-30 iterations is standard\n","CONFIDENCE_ALPHA = 40       # c_ui = 1 + alpha * r_ui\n","RELEVANCE_THRESH = 3.5\n","TOP_K            = 10\n","MAX_MAP_USERS    = 5_000\n","RANDOM_SEED      = 42\n","BATCH_SIZE       = 1024     # Batch size for linear system solver on GPU\n","\n","\n","# ── 1. LOAD DATA ──────────────────────────────────────────────────────────────\n","def load_df(path):\n","    print(f\"Loading {path}...\", flush=True)\n","    t0 = time.time()\n","    df = pd.read_parquet(path) if path.endswith(\".parquet\") else pd.read_csv(path)\n","\n","    # Deduplicate columns upfront to prevent duplicate column bugs\n","    df = df.loc[:, ~df.columns.duplicated()]\n","\n","    rename = {}\n","    for col in df.columns:\n","        cl = col.lower()\n","        if cl in (\"customerid\",\"userid\",\"user_id\",\"customer_id\"): rename[col]=\"CustomerID\"\n","        elif cl in (\"movieid\",\"itemid\",\"movie_id\",\"item_id\"):      rename[col]=\"MovieID\"\n","        elif cl in (\"rating\",\"ratings\"):                           rename[col]=\"Rating\"\n","        elif cl in (\"date\",\"timestamp\",\"time\"):                    rename[col]=\"Date\"\n","\n","    df.rename(columns=rename, inplace=True)\n","    df = df.loc[:, ~df.columns.duplicated()] # Force unique columns after rename\n","\n","    df[\"CustomerID\"] = df[\"CustomerID\"].astype(\"int32\")\n","    df[\"MovieID\"]    = df[\"MovieID\"].astype(\"int32\")\n","    df[\"Rating\"]     = df[\"Rating\"].astype(\"float32\")\n","    print(f\"   {len(df):,} rows loaded in {time.time()-t0:.1f}s\")\n","    return df\n","\n","\n","# ── 2. ENCODERS ───────────────────────────────────────────────────────────────\n","def build_encoders(train_df):\n","    # Sort CustomerIDs by frequency (ratings count) ascending\n","    user_counts = train_df[\"CustomerID\"].value_counts(ascending=True)\n","    sorted_users = user_counts.index.values\n","\n","    # Sort MovieIDs by frequency (ratings count) ascending\n","    item_counts = train_df[\"MovieID\"].value_counts(ascending=True)\n","    sorted_items = item_counts.index.values\n","\n","    u_enc = {u: i for i, u in enumerate(sorted_users)}\n","    i_enc = {v: i for i, v in enumerate(sorted_items)}\n","    return u_enc, i_enc\n","\n","\n","# ── 3. PYTORCH ALS SOLVER ON MPS ──────────────────────────────────────────────\n","class PyTorchALS:\n","    def __init__(self, n_users, n_items, global_mean, factors=FACTORS, regularization=REGULARIZATION, device=\"cpu\"):\n","        self.n_users = n_users\n","        self.n_items = n_items\n","        self.global_mean = global_mean\n","        self.factors = factors\n","        self.reg = regularization\n","        self.device = device\n","\n","        # Initialize user and item factors randomly on CPU, then transfer to device\n","        generator = torch.Generator().manual_seed(RANDOM_SEED)\n","        self.user_factors = torch.randn(n_users, factors, generator=generator, device=\"cpu\").to(device) * 0.01\n","        self.item_factors = torch.randn(n_items, factors, generator=generator, device=\"cpu\").to(device) * 0.01\n","        self.user_biases = torch.zeros(n_users, device=device)\n","        self.item_biases = torch.zeros(n_items, device=device)\n","\n","    def train_step(self, user_items, user_ratings, item_users, item_ratings, epoch_desc=\"\"):\n","        # ── 1. UPDATE USER FACTORS (holding item factors fixed) ────────────────\n","        self.user_factors, self.user_biases = self._solve_factors(\n","            self.user_factors, self.item_factors, self.user_biases, self.item_biases,\n","            user_items, user_ratings, update_type=\"Users\"\n","        )\n","\n","        # ── 2. UPDATE ITEM FACTORS (holding user factors fixed) ────────────────\n","        self.item_factors, self.item_biases = self._solve_factors(\n","            self.item_factors, self.user_factors, self.item_biases, self.user_biases,\n","            item_users, item_ratings, update_type=\"Items\"\n","        )\n","\n","    def _solve_factors(self, X, Y, biases_X, biases_Y, interactions, ratings_list, update_type=\"user\"):\n","        n_entities = X.shape[0]\n","        new_X = torch.zeros_like(X)\n","        new_biases = torch.zeros_like(biases_X)\n","        I = torch.eye(self.factors, device=self.device)\n","\n","        start = 0\n","        pbar = tqdm(total=n_entities, desc=f\"Solving {update_type}\", leave=False)\n","        while start < n_entities:\n","            # Dynamic batch sizing using a candidate ceiling of 256 for Colab stability\n","            candidate_size = 256\n","            candidate_end = min(start + candidate_size, n_entities)\n","            peek_items = interactions[start:candidate_end]\n","            local_max_len = max(len(items) for items in peek_items) if len(peek_items) > 0 else 0\n","\n","            if local_max_len > 0:\n","                safe_batch_size = max(1, 100_000_000 // (local_max_len * self.factors))\n","                batch_size = min(candidate_size, safe_batch_size)\n","            else:\n","                batch_size = candidate_size\n","\n","            end = min(start + batch_size, n_entities)\n","            batch_items = interactions[start:end]\n","            batch_ratings = ratings_list[start:end]\n","            ents_t = torch.arange(start, end, device=self.device)\n","\n","            max_len = max(len(items) for items in batch_items)\n","            if max_len == 0:\n","                new_X[start:end] = 0.0\n","                new_biases[start:end] = 0.0\n","                start = end\n","                pbar.update(batch_size)\n","                continue\n","\n","            # Padded NumPy views prepared on CPU (bypasses MPS/CUDA scatter bottlenecks)\n","            padded_items = np.zeros((len(batch_items), max_len), dtype=np.int64)\n","            padded_ratings = np.zeros((len(batch_ratings), max_len), dtype=np.float32)\n","            for idx, (items, rats) in enumerate(zip(batch_items, batch_ratings)):\n","                l = len(items)\n","                padded_items[idx, :l] = items\n","                padded_ratings[idx, :l] = rats\n","\n","            t_items = torch.from_numpy(padded_items).to(self.device)\n","            t_ratings = torch.from_numpy(padded_ratings).to(self.device)\n","            mask = t_ratings > 0.0\n","            n_rated = mask.sum(dim=1).float()\n","\n","            V = Y[t_items] # (B, max_len, factors)\n","            b_Y_batch = biases_Y[t_items] # (B, max_len)\n","\n","            # --- 1. Update Biases ---\n","            X_batch = X[ents_t] # (B, factors)\n","            dot_products = (X_batch.unsqueeze(1) * V).sum(dim=2) # (B, max_len)\n","\n","            sum_term = ((t_ratings - self.global_mean - b_Y_batch - dot_products) * mask).sum(dim=1)\n","            b_new = sum_term / (n_rated + self.reg)\n","            new_biases[ents_t] = b_new\n","\n","            # --- 2. Update Latent Factors ---\n","            residuals = (t_ratings - self.global_mean - b_new.unsqueeze(1) - b_Y_batch) * mask\n","            V_masked = V * mask.unsqueeze(-1)\n","\n","            A = V.transpose(1, 2) @ V_masked + self.reg * I.unsqueeze(0)\n","            b_vec = (V * residuals.unsqueeze(-1)).sum(dim=1)\n","\n","            L = torch.linalg.cholesky(A)\n","            x_new = torch.cholesky_solve(b_vec.unsqueeze(-1), L).squeeze(-1)\n","            new_X[ents_t] = x_new\n","\n","            start = end\n","            pbar.update(batch_size)\n","\n","        pbar.close()\n","        return new_X, new_biases\n","\n","\n","def evaluate_rmse(model, test_df, u_enc, i_enc, chunk=2_000_000):\n","    print(\"\\nEvaluating RMSE (chunked, all test rows)...\", flush=True)\n","    user_factors = model.user_factors.cpu().numpy()\n","    item_factors = model.item_factors.cpu().numpy()\n","    user_biases = model.user_biases.cpu().numpy()\n","    item_biases = model.item_biases.cpu().numpy()\n","\n","    sse, n = 0.0, 0\n","    for start in tqdm(range(0, len(test_df), chunk), desc=\"RMSE\"):\n","        c = test_df.iloc[start : start + chunk]\n","\n","        # Map raw CustomerID/MovieID to inner indexes\n","        u_idx = c[\"CustomerID\"].map(u_enc).fillna(-1).astype(np.int32).values\n","        i_idx = c[\"MovieID\"].map(i_enc).fillna(-1).astype(np.int32).values\n","        true_r = c[\"Rating\"].values.astype(np.float32)\n","\n","        # Initialize predictions with the global mean\n","        est = np.full(len(c), model.global_mean, dtype=np.float32)\n","\n","        user_is_warm = u_idx >= 0\n","        item_is_warm = i_idx >= 0\n","        both_warm = user_is_warm & item_is_warm\n","\n","        # Add user biases for warm users\n","        if user_is_warm.any():\n","            est[user_is_warm] += user_biases[u_idx[user_is_warm]]\n","\n","        # Add item biases for warm items\n","        if item_is_warm.any():\n","            est[item_is_warm] += item_biases[i_idx[item_is_warm]]\n","\n","        # Add latent dot products when both are warm\n","        if both_warm.any():\n","            est[both_warm] += (user_factors[u_idx[both_warm]] * item_factors[i_idx[both_warm]]).sum(axis=1)\n","\n","        est = np.clip(est, 1.0, 5.0)\n","        sse += np.sum((est - true_r) ** 2)\n","        n += len(true_r)\n","\n","        del c, u_idx, i_idx, true_r, user_is_warm, item_is_warm, both_warm, est\n","        gc.collect()\n","\n","    rmse = (sse / n) ** 0.5 if n > 0 else 0.0\n","    print(f\"   RMSE: {rmse:.4f}  (n={n:,})\")\n","    return rmse\n","\n","\n","def evaluate_map_at_k(model, test_df, u_enc, i_enc, k=TOP_K, max_users=MAX_MAP_USERS):\n","    print(f\"\\nEvaluating MAP@{k} (all test rows)...\", flush=True)\n","\n","    # Filter test cases with rating >= RELEVANCE_THRESH (no warm mapping restriction)\n","    pos = test_df[test_df[\"Rating\"] >= RELEVANCE_THRESH].copy()\n","\n","    if pos.empty:\n","        print(f\"   MAP@{k}: 0.0000 (No test cases matched criteria)\")\n","        return 0.0\n","\n","    user_rel = pos.groupby(\"CustomerID\")[\"MovieID\"].apply(set).to_dict()\n","    candidate_users = list(user_rel.keys())\n","\n","    if max_users and len(candidate_users) > max_users:\n","        rng = np.random.default_rng(RANDOM_SEED)\n","        candidate_users = rng.choice(candidate_users, size=max_users, replace=False).tolist()\n","\n","    user_factors = model.user_factors.cpu().numpy()\n","    item_factors = model.item_factors.cpu().numpy()\n","    user_biases = model.user_biases.cpu().numpy()\n","    item_biases = model.item_biases.cpu().numpy()\n","\n","    ap_list = []\n","    for uid in tqdm(candidate_users, desc=\"MAP\"):\n","        u_idx = u_enc.get(uid, -1)\n","        # relevant set maps raw MovieID to inner item ID\n","        rel_set = {i_enc[mid] for mid in user_rel[uid] if mid in i_enc}\n","\n","        # Predict all item scores for this user (with fallback for cold users)\n","        if u_idx >= 0:\n","            scores = model.global_mean + user_biases[u_idx] + item_biases + user_factors[u_idx] @ item_factors.T\n","        else:\n","            scores = model.global_mean + item_biases\n","\n","        # Sort scores in descending order\n","        top_k_idx = np.argsort(-scores)[:k]\n","\n","        # Calculate Average Precision\n","        hits, precision_sum = 0, 0.0\n","        for rank, inner_iid in enumerate(top_k_idx, start=1):\n","            if inner_iid in rel_set:\n","                hits += 1\n","                precision_sum += hits / rank\n","\n","        # Denominator represents total relevant items user has (capped at k)\n","        ap_list.append(precision_sum / min(len(user_rel[uid]), k))\n","\n","    map_k = float(np.mean(ap_list)) if ap_list else 0.0\n","    print(f\"   MAP@{k}: {map_k:.4f}  ({len(ap_list):,} users)\")\n","    return map_k\n","\n","\n","# ── 5. MAIN ───────────────────────────────────────────────────────────────────\n","def main():\n","    # Detect Apple Silicon MPS or fall back to CPU\n","    if torch.cuda.is_available():\n","        device = torch.device(\"cuda\")\n","    elif torch.backends.mps.is_available():\n","        device = torch.device(\"mps\")\n","    else:\n","        device = torch.device(\"cpu\")\n","    print(f\"Using Device: {device}\", flush=True)\n","\n","    candidate_paths = [\n","        \"\",  # Current directory\n","        \"/content/drive/Sharedrives/netflixrecommendationsystem/dataset\",\n","        \"/content/drive/Shareddrives/netflixrecommendationsystem/dataset\"\n","    ]\n","    DATA_DIR = \"\"\n","    for path in candidate_paths:\n","        if os.path.exists(os.path.join(path, \"train.parquet\")):\n","            DATA_DIR = path\n","            print(f\"Detected dataset directory: '{DATA_DIR if DATA_DIR else '.'}'\", flush=True)\n","            break\n","\n","    train_path = os.path.join(DATA_DIR, \"train.parquet\")\n","    test_path  = os.path.join(DATA_DIR, \"test.parquet\")\n","\n","    # Load data\n","    train_df = load_df(train_path)\n","    test_df  = load_df(test_path)\n","\n","    # Encode users and items sequentially\n","    u_enc, i_enc = build_encoders(train_df)\n","    n_users, n_items = len(u_enc), len(i_enc)\n","    print(f\"   {n_users:,} users | {n_items:,} items\")\n","\n","    # ── High-Performance Grouping via NumPy Split ─────────────────────────────\n","    # This replaces groupby-apply, running in 3 seconds instead of 40 seconds.\n","    print(\"Grouping user ratings using NumPy splits...\", flush=True)\n","    # Map raw IDs to inner IDs first so we can sort by inner ID (which is ordered by length)\n","    train_df[\"UserIdx\"] = train_df[\"CustomerID\"].map(u_enc).astype(np.int32)\n","    train_df.sort_values(\"UserIdx\", inplace=True)\n","\n","    cust_ids = train_df[\"UserIdx\"].values\n","    movie_ids = train_df[\"MovieID\"].map(i_enc).values.astype(np.int32)\n","    ratings = train_df[\"Rating\"].values.astype(np.float32)\n","\n","    split_u = np.where(cust_ids[:-1] != cust_ids[1:])[0] + 1\n","    user_items = np.split(movie_ids, split_u)\n","    user_ratings = np.split(ratings, split_u)\n","\n","    print(\"Grouping item ratings using NumPy splits...\", flush=True)\n","    # Map raw IDs to inner IDs first so we can sort by inner ID (which is ordered by length)\n","    train_df[\"MovieIdx\"] = train_df[\"MovieID\"].map(i_enc).astype(np.int32)\n","    train_df.sort_values(\"MovieIdx\", inplace=True)\n","\n","    cust_ids = train_df[\"UserIdx\"].values\n","    movie_ids = train_df[\"MovieIdx\"].values\n","    ratings = train_df[\"Rating\"].values.astype(np.float32)\n","\n","    split_i = np.where(movie_ids[:-1] != movie_ids[1:])[0] + 1\n","    item_users = np.split(cust_ids, split_i)\n","    item_ratings = np.split(ratings, split_i)\n","\n","    # Compute global mean rating\n","    global_mean = float(ratings.mean())\n","    del train_df; gc.collect()\n","\n","    # ── Initialize ALS model on MPS/CPU ───────────────────────────────────────\n","    als = PyTorchALS(n_users, n_items, global_mean, factors=FACTORS, regularization=REGULARIZATION, device=device)\n","\n","    # ── Training Loop ─────────────────────────────────────────────────────────\n","    print(f\"\\nTraining PyTorch ALS on {device}...\", flush=True)\n","    for epoch in range(1, ITERATIONS + 1):\n","        t_start = time.time()\n","        epoch_desc = f\"Epoch {epoch:2d}/{ITERATIONS}\"\n","        als.train_step(user_items, user_ratings, item_users, item_ratings, epoch_desc=epoch_desc)\n","        print(f\"   Epoch {epoch:2d}/{ITERATIONS} finished in {time.time()-t_start:.1f}s\")\n","        gc.collect()\n","\n","    # ── Evaluation ────────────────────────────────────────────────────────────\n","    rmse = evaluate_rmse(als, test_df, u_enc, i_enc)\n","    map_k = evaluate_map_at_k(als, test_df, u_enc, i_enc)\n","\n","    print(f\"\\n{'='*50}\")\n","    print(f\"  RMSE   : {rmse:.4f}\")\n","    print(f\"  MAP@{TOP_K}  : {map_k:.4f}\")\n","    print(f\"{'='*50}\", flush=True)\n","\n","    # ── SAVE MODEL AND ENCODERS ───────────────────────────────────────────────\n","    # Save directly to target path if it exists, otherwise fallback to local directory\n","    target_dir = \"/content/drive/Shareddrives/netflixrecommendationsystem\"\n","    if os.path.exists(target_dir):\n","        model_save_path = os.path.join(target_dir, \"implicit_als_model.pkl\")\n","    else:\n","        model_save_path = \"implicit_als_model.pkl\"\n","    print(f\"Saving PyTorch ALS model and encoders to {model_save_path}...\", flush=True)\n","\n","    # Store weights as standard NumPy arrays for serialization safety\n","    model_data = {\n","        \"user_factors\": als.user_factors.cpu().numpy(),\n","        \"item_factors\": als.item_factors.cpu().numpy(),\n","        \"user_biases\": als.user_biases.cpu().numpy(),\n","        \"item_biases\": als.item_biases.cpu().numpy(),\n","        \"global_mean\": als.global_mean,\n","        \"u_enc\": u_enc,\n","        \"i_enc\": i_enc,\n","        \"factors\": FACTORS,\n","        \"regularization\": REGULARIZATION,\n","    }\n","\n","    with open(model_save_path, \"wb\") as f:\n","        pickle.dump(model_data, f)\n","    print(\"Model saved successfully!\", flush=True)\n","\n","\n","if __name__ == \"__main__\":\n","    main()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":849,"referenced_widgets":["eb66ba2e7376452b9665b46f0f64bf99","0b5b945c80934fa8a245064990ed70ac","e2504bcf45164a4e8f2151ac11530554"