fRelease' in chunk.columns:\n","        valid_years = chunk['YearOfRelease'].dropna()\n","        year_sum += valid_years.sum()\n","        year_count += valid_years.count()\n","\n","avg_rating = rating_sum / rating_count if rating_count > 0 else 0.0\n","avg_year = year_sum / year_count if year_count > 0 else 0.0\n","\n","print(\"\\n--- Global Averages ---\")\n","print(f\"Rating: {avg_rating:.4f}\")\n","print(f\"YearOfRelease: {avg_year:.4f}\")\n","print(\"\\n\" + \"=\"*50 + \"\\n\")\n","\n","# Free up memory immediately\n","del df_head, chunk\n","gc.collect()"],"metadata":{"id":"NnC7sKLD1yu_","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781257033965,"user_tz":-330,"elapsed":4399,"user":{"displayName":"MANGALAPALLY SAI VASHISTA 24117071","userId":"18399268862536660880"}},"outputId":"9b271a60-b2e4-439d-995f-06cad2c6a851"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["--- Dataset Columns and Sample ---\n","['MovieID', 'CustomerID', 'Rating', 'Date', 'YearOfRelease', 'Title']\n","   MovieID  CustomerID  Rating       Date  YearOfRelease            Title\n","0        1     1488844       3 2005-09-06         2003.0  Dinosaur Planet\n","1        1      822109       5 2005-05-13         2003.0  Dinosaur Planet\n","2        1      885013       4 2005-10-19         2003.0  Dinosaur Planet\n","3        1       30878       4 2005-12-26         2003.0  Dinosaur Planet\n","4        1      823519       3 2004-05-03         2003.0  Dinosaur Planet\n","\n","==================================================\n","\n","Computing global averages chunk-by-chunk...\n","\n","--- Global Averages ---\n","Rating: 3.6043\n","YearOfRelease: 1993.9114\n","\n","==================================================\n","\n"]},{"output_type":"execute_result","data":{"text/plain":["15"]},"metadata":{},"execution_count":6}]},{"cell_type":"code","source":["\"\"\"rename train.parquet\"\"\"\n","import os\n","\n","if os.path.exists('/content/drive/Shareddrives/netflixrecommendationsystem/dataset/train.parquet'):\n","    os.rename(\n","        '/content/drive/Shareddrives/netflixrecommendationsystem/dataset/train.parquet',\n","        '/content/drive/Shareddrives/netflixrecommendationsystem/dataset/raw_ratings.parquet'\n","    )\n","    print(\"Successfully renamed raw dataset to 'raw_ratings.parquet'!\")\n","else:\n","    print(\"File already renamed or not found.\")"],"metadata":{"id":"LQqEFNN05GqM","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781257034138,"user_tz":-330,"elapsed":169,"user":{"displayName":"MANGALAPALLY SAI VASHISTA 24117071","userId":"18399268862536660880"}},"outputId":"b2867f7c-5a80-4e84-eed5-0beb6bf7282e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Successfully renamed raw dataset to 'raw_ratings.parquet'!\n"]}]},{"cell_type":"code","source":["\"\"\"create train-test split\"\"\"\n","import pandas as pd\n","import numpy as np\n","import pyarrow as pa\n","import pyarrow.parquet as pq\n","import pickle\n","import gc\n","\n","file_path_pq = '/content/drive/Shareddrives/netflixrecommendationsystem/dataset/raw_ratings.parquet'\n","train_out = '/content/drive/Shareddrives/netflixrecommendationsystem/dataset/train.parquet'\n","test_out = '/content/drive/Shareddrives/netflixrecommendationsystem/dataset/test.parquet'\n","\n","# Pass 1: Count user and movie interactions\n","user_counts_dict = {}\n","movie_counts_dict = {}\n","\n","print(\"Pass 1: Counting interactions chunk-by-chunk...\")\n","pf = pq.ParquetFile(file_path_pq)\n","for i in range(pf.num_row_groups):\n","    chunk = pf.read_row_group(i, columns=['CustomerID', 'MovieID']).to_pandas()\n","    # Count CustomerID\n","    for uid, count in chunk['CustomerID'].value_counts().items():\n","        user_counts_dict[uid] = user_counts_dict.get(uid, 0) + count\n","    # Count MovieID\n","    for mid, count in chunk['MovieID'].value_counts().items():\n","        movie_counts_dict[mid] = movie_counts_dict.get(mid, 0) + count\n","\n","# Filter active users and popular movies\n","active_users = {uid for uid, count in user_counts_dict.items() if count >= 50}\n","popular_movies = {mid for mid, count in movie_counts_dict.items() if count >= 100}\n","\n","print(f\"  Active Users: {len(active_users):,}\")\n","print(f\"  Popular Movies: {len(popular_movies):,}\")\n","\n","del user_counts_dict, movie_counts_dict\n","gc.collect()\n","\n","\n","# Pass 2: Collect dates and unique IDs to build mapping and find split threshold\n","print(\"\\nPass 2: Collecting dates and unique IDs...\")\n","dates_list = []\n","unique_users_set = set()\n","unique_movies_set = set()\n","\n","for i in range(pf.num_row_groups):\n","    chunk = pf.read_row_group(i, columns=['CustomerID', 'MovieID', 'Date']).to_pandas()\n","    mask = chunk['CustomerID'].isin(active_users) & chunk['MovieID'].isin(popular_movies)\n","    filtered = chunk[mask]\n","\n","    if not filtered.empty:\n","        dates_list.append(filtered['Date'].values)\n","        unique_users_set.update(filtered['CustomerID'].unique())\n","        unique_movies_set.update(filtered['MovieID'].unique())\n","\n","# Concatenate all dates to find temporal 80th percentile threshold\n","all_dates = np.concatenate(dates_list)\n","split_date = np.percentile(all_dates, 80)\n","print(f\"  Split Date Threshold: {np.datetime_as_string(split_date, unit='D')}\")\n","\n","del dates_list, all_dates\n","gc.collect()\n","\n","\n","# Build ID mappings\n","user_map = {uid: idx for idx, uid in enumerate(unique_users_set)}\n","movie_map = {mid: idx for idx, mid in enumerate(unique_movies_set)}\n","del unique_users_set, unique_movies_set\n","gc.collect()\n","\n","\n","# Pass 3: Process, Map, and write train/test sets directly to disk\n","print(\"\\nPass 3: Splitting and writing incrementally to Parquet...\")\n","train_writer = None\n","test_writer = None\n","\n","for i in range(pf.num_row_groups):\n","    chunk = pf.read_row_group(i, columns=['CustomerID', 'MovieID', 'Rating', 'Date']).to_pandas()\n","    mask = chunk['CustomerID'].isin(active_users) & chunk['MovieID'].isin(popular_movies)\n","    filtered = chunk[mask].copy()\n","\n","    if filtered.empty:\n","        continue\n","\n","    # Map IDs\n","    filtered['user_id'] = filtered['CustomerID'].map(user_map).astype('int32')\n","    filtered['item_id'] = filtered['MovieID'].map(movie_map).astype('int32')\n","\n","    # Split by date\n","    train_chunk = filtered[filtered['Date'] <= split_date]\n","    test_chunk = filtered[filtered['Date'] > split_date]\n","\n","    # Write train chunk\n","    if not train_chunk.empty:\n","        table = pa.Table.from_pandas(train_chunk)\n","        if train_writer is None:\n","            train_writer = pq.ParquetWriter(train_out, table.schema, compression='snappy')\n","        train_writer.write_table(table)\n","\n","    # Write test chunk\n","    if not test_chunk.empty:\n","        table = pa.Table.from_pandas(test_chunk)\n","        if test_writer is None:\n","            test_writer = pq.ParquetWriter(test_out, table.schema, compression='snappy')\n","        test_writer.write_table(table)\n","\n","# Close writers\n","if train_writer:\n","    train_writer.close()\n","if test_writer:\n","    test_writer.close()\n","\n","# Save mapping files\n","with open('maps.pkl', 'wb') as f:\n","    pickle.dump({'user_map': user_map, 'movie_map': movie_map}, f)\n","\n","print(\"Saved train.parquet, test.parquet, and maps.pkl successfully!\")\n","\n","del active_users, popular_movies, user_map, movie_map\n","gc.collect()"],"metadata":{"id":"XDAenJzr4MGA","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781257288178,"user_tz":-330,"elapsed":254036,"user":{"displayName":"MANGALAPALLY SAI VASHISTA 24117071","userId":"18399268862536660880"}},"outputId":"7ac4d62d-b6ea-45d4-fd22-df1edd24fef6"},"execution_count":null,"outputs":[{"output_type":