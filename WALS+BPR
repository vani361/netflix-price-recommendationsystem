"source":["#!/usr/bin/env python3\n","\"\"\"\n","Netflix WALS (Weighted Alternating Least Squares) — PyTorch CUDA/MPS\n","===================================================================\n","Improvements over v1:\n","  - Joint bias+factor solve (biases recomputed from updated factors each step)\n","  - Popularity-penalized MAP scoring (item_score -= alpha * log(item_pop))\n","  - Convergence monitoring via per-epoch train loss\n","  - Higher default regularization (0.1) and iterations (30)\n","  - MAP eval bug fix: retain CustomerID in test_df\n","  - Optional early stopping\n","\"\"\"\n","\n","import gc\n","import os\n","import time\n","import pickle\n","import numpy as np\n","import pandas as pd\n","import torch\n","from tqdm.auto import tqdm\n","\n","# ── CONFIG ────────────────────────────────────────────────────────────────────\n","FACTORS            = 128\n","REGULARIZATION     = 0.1        # was 0.01 — too low for 128 factors\n","ITERATIONS         = 30         # was 20 — WALS needs more for high-factor models\n","RELEVANCE_THRESH   = 3.5\n","TOP_K              = 10\n","MAX_MAP_USERS      = 5_000\n","RANDOM_SEED        = 42\n","POPULARITY_PENALTY = 0.15       # alpha for MAP score: score -= alpha * log(item_pop)\n","EARLY_STOP_ROUNDS  = 4          # stop if MAP doesn't improve for this many epochs\n","EVAL_EVERY         = 5          # evaluate MAP every N epochs (expensive)\n","\n","# ── 1. LOAD DATA ──────────────────────────────────────────────────────────────\n","def load_df(path):\n","    print(f\"Loading {path}...\", flush=True)\n","    t0 = time.time()\n","    if path.endswith(\".parquet\"):\n","        import pyarrow.parquet as pq\n","        file_cols = pq.ParquetFile(path).schema.names\n","    else:\n","        file_cols = list(pd.read_csv(path, nrows=1).columns)\n","\n","    col_map = {}\n","    for col in file_cols:\n","        cl = col.lower()\n","        if cl in (\"customerid\", \"userid\", \"user_id\", \"customer_id\"): col_map[\"CustomerID\"] = col\n","        elif cl in (\"movieid\", \"itemid\", \"movie_id\", \"item_id\"):      col_map[\"MovieID\"] = col\n","        elif cl in (\"rating\", \"ratings\"):                              col_map[\"Rating\"] = col\n","\n","    load_cols = [col_map[k] for k in [\"CustomerID\", \"MovieID\", \"Rating\"] if k in col_map]\n","    df = pd.read_parquet(path, columns=load_cols) if path.endswith(\".parquet\") else pd.read_csv(path, usecols=load_cols)\n","    rename = {v: k for k, v in col_map.items()}\n","    df.rename(columns=rename, inplace=True)\n","    df = df.loc[:, ~df.columns.duplicated()]\n","    df[\"CustomerID\"] = df[\"CustomerID\"].astype(\"int32\")\n","    df[\"MovieID\"]    = df[\"MovieID\"].astype(\"int32\")\n","    df[\"Rating\"]     = df[\"Rating\"].astype(\"float32\")\n","    print(f\"   {len(df):,} rows loaded in {time.time()-t0:.1f}s\")\n","    return df\n","\n","# ── 2. ENCODERS & FREQUENCIES ─────────────────────────────────────────────────\n","def build_encoders_and_frequencies(train_df):\n","    user_counts = train_df[\"CustomerID\"].value_counts(ascending=True)\n","    item_counts = train_df[\"MovieID\"].value_counts(ascending=True)\n","    u_enc = {u: i for i, u in enumerate(user_counts.index.values)}\n","    i_enc = {v: i for i, v in enumerate(item_counts.index.values)}\n","    return u_enc, i_enc, user_counts.values.astype(np.float32), item_counts.values.astype(np.float32)\n","\n","# ── 3. PYTORCH WALS SOLVER ────────────────────────────────────────────────────\n","class PyTorchWALS:\n","    def __init__(self, n_users, n_items, global_mean, item_pop_log,\n","                 factors=FACTORS, regularization=REGULARIZATION, device=\"cpu\"):\n","        self.n_users = n_users\n","        self.n_items = n_items\n","        self.global_mean = global_mean\n","        self.item_pop_log = item_pop_log        # log(e + item_count), shape (n_items,)\n","        self.factors = factors\n","        self.reg = regularization\n","        self.device = device\n","\n","        generator = torch.Generator().manual_seed(RANDOM_SEED)\n","        self.user_factors = torch.randn(n_users, factors, generator=generator).to(device) * 0.01\n","        self.item_factors = torch.randn(n_items, factors, generator=generator).to(device) * 0.01\n","        self.user_biases = torch.zeros(n_users, device=device)\n","        self.item_biases = torch.zeros(n_items, device=device)\n","\n","    def train_step(self, user_indptr, user_items_flat, user_ratings_flat, user_weights_flat,\n","                   item_indptr, item_users_flat, item_ratings_flat, item_weights_flat):\n","        # Update users (items fixed)\n","        self.user_factors, self.user_biases = self._solve_factors(\n","            self.user_factors, self.item_factors, self.user_biases, self.item_biases,\n","            user_indptr, user_items_flat, user_ratings_flat, user_weights_flat, \"Users\"\n","        )\n","        # Update items (users fixed)\n","        self.item_factors, self.item_biases = self._solve_factors(\n","            self.item_factors, self.user_factors, self.item_biases, self.user_biases,\n","            item_indptr, item_users_flat, item_ratings_flat, item_weights_flat, \"Items\"\n","        )\n","\n","    def _solve_factors(self, X, Y, biases_X, biases_Y, indptr, items_flat,\n","                       ratings_flat, weights_flat, update_type=\"user\"):\n","        n_entities = X.shape[0]\n","        new_X = torch.zeros_like(X)\n","        new_biases = torch.zeros_like(biases_X)\n","        I = torch.eye(self.factors, device=self.device)\n","\n","        start = 0\n","        pbar = tqdm(total=n_entities, desc=f\"Solving {update_type}\", leave=False)\n","        while start < n_entities:\n","            candidate_size = 256\n","            candidate_end = min(start + candidate_size, n_entities)\n","            lens = indptr[start+1 : candidate_end+1] - indptr[start : candidate_end]\n","            local_max_len = int(lens.max()) if len(lens) > 0 else 0\n","\n","            if local_max_len > 0:\n","                safe_batch_size = max(1, 100_000_000 // (local_max_len * self.factors))\n","                batch_size = min(candidate_size, safe_batch_size)\n","            else:\n","                batch_size = candidate_size\n","\n","            end = min(start + batch_size, n_entities)\n","            ents_t = torch.arange(start, end, device=self.device)\n","            batch_lens = indptr[start+1 : end+1] - indptr[start : end]\n","            max_len = int(batch_lens.max()) if len(batch_lens) > 0 else 0\n","\n","            if max_len == 0:\n","                new_X[start:end] = 0.0\n","                new_biases[start:end] = 0.0\n","                start = end\n","                pbar.update(batch_size)\n","                continue\n","\n","            padded_items   = np.zeros((end - start, max_len), dtype=np.int64)\n","            padded_ratings = np.zeros((end - start, max_len), dtype=np.float32)\n","            padded_weights = np.zeros((end - start, max_len), dtype=np.float32)\n","            for idx, u in enumerate(range(start, end)):\n","                s_ptr, e_ptr = indptr[u], indptr[u+1]\n","                l = e_ptr - s_ptr\n","                if l > 0:\n","                    padded_items[idx, :l]   = items_flat[s_ptr:e_ptr]\n","                    padded_ratings[idx, :l] = ratings_flat[s_ptr:e_ptr]\n","                    padded_weights[idx, :l] = weights_flat[s_ptr:e_ptr]\n","\n","            t_items   = torch.from_numpy(padded_items).to(self.device)\n","            t_ratings = torch.from_numpy(padded_ratings).to(self.device)\n","            t_weights = torch.from_numpy(padded_weights).to(self.device)\n","            mask = t_weights > 0                           # (B, max_len) valid positions\n","\n","            V     = Y[t_items]                             # (B, max_len, F)\n","            b_Y   = biases_Y[t_items]                      # (B, max_len)\n","\n","            # ── FIX: joint bias + factor solve ────────────────────────────────\n","            # Step 1: solve bias with CURRENT factors from X (not updated yet)\n","            X_curr = X[ents_t]                             # (B, F)\n","            dot    = (X_curr.unsqueeze(1) * V).sum(-1)     # (B, max_len)\n","            resid_for_bias = (t_ratings - self.global_mean - b_Y - dot) * t_weights\n","            w_sum  = t_weights.sum(-1).clamp(min=1e-9)\n","            b_new  = resid_for_bias.sum(-1) / (w_sum + self.reg)\n","            new_biases[ents_t] = b_new\n","\n","            # Step 2: solve factors using freshly computed bias b_new\n","            resid  = (t_ratings - self.global_mean - b_new.unsqueeze(1) - b_Y)\n","            V_w    = V * t_weights.unsqueeze(-1)           # (B, max_len, F)\n","            A      = V.transpose(1,2) @ V_w + self.reg * I.unsqueeze(0)   # (B, F, F)\n","            b_vec  = (V * (resid * t_weights).unsqueeze(-1)).sum(1)        # (B, F)\n","\n","            L      = torch.linalg.cholesky(A)\n","            x_new  = torch.cholesky_solve(b_vec.unsqueeze(-1), L).squeeze(-1)\n","            new_X[ents_t] = x_new\n","\n","            start = end\n","            pbar.update(batch_size)\n","\n","        pbar.close()\n","        return new_X, new_biases\n","\n","    def train_loss(self, user_indptr, user_items_flat, user_ratings_flat, user_weights_flat,\n","                   sample=200_000):\n","        \"\"\"Weighted MSE on a random sample of training interactions.\"\"\"\n","        n = len(user_ratings_flat)\n","        idx = np.random.default_rng(0).choice(n, min(sample, n), replace=False)\n","        u_flat_idx = np.searchsorted(user_indptr[1:], idx, side='right')\n","        i_flat     = user_items_flat[idx]\n","        r_flat     = user_ratings_flat[idx]\n","        w_flat     = user_weights_flat[idx]\n","\n","        uf = self.user_factors.cpu().numpy()\n","        if_= self.item_factors.cpu().numpy()\n","        ub = self.user_biases.cpu().numpy()\n","        ib = self.item_biases.cpu().numpy()\n","        pred = (self.global_mean + ub[u_flat_idx] + ib[i_flat]\n","                + (uf[u_flat_idx] * if_[i_flat]).sum(1))\n","        wmse = np.sum(w_flat * (pred - r_flat)**2) / np.sum(w_flat)\n","        return float(wmse)\n","\n","# ── 4. EVALUATIONS ────────────────────────────────────────────────────────────\n","def evaluate_rmse(model, test_df, chunk=2_000_000):\n","    print(\"\\nEvaluating RMSE...\", flush=True)\n","    uf = model.user_factors.cpu().numpy()\n","    if_= model.item_factors.cpu().numpy()\n","    ub = model.user_biases.cpu().numpy()\n","    ib = model.item_biases.cpu().numpy()\n","    sse, n = 0.0, 0\n","    for s in tqdm(range(0, len(test_df), chunk), desc=\"RMSE\"):\n","        e = s + chunk\n","        u_idx  = test_df[\"UserIdx\"].values[s:e]\n","        i_idx  = test_df[\"MovieIdx\"].values[s:e]\n","        true_r = test_df[\"Rating\"].values[s:e]\n","        est = np.full(len(u_idx), model.global_mean, dtype=np.float32)\n","        uw = u_idx >= 0;  iw = i_idx >= 0;  bw = uw & iw\n","        if uw.any(): est[uw] += ub[u_idx[uw]]\n","        if iw.any(): est[iw] += ib[i_idx[iw]]\n","        if bw.any(): est[bw] += (uf[u_idx[bw]] * if_[i_idx[bw]]).sum(1)\n","        est = np.clip(est, 1.0, 5.0)\n","        sse += np.sum((est - true_r)**2);  n += len(true_r)\n","        del u_idx, i_idx, true_r, est;  gc.collect()\n","    rmse = (sse / n)**0.5 if n > 0 else 0.0\n","    print(f\"   RMSE: {rmse:.4f}  (n={n:,})\")\n","    return rmse\n","\n","def evaluate_map_at_k(model, test_df, item_pop_log, alpha=POPULARITY_PENALTY, k=TOP_K, max_users=MAX_MAP_USERS):\n","    \"\"\"\n","    MAP@k with popularity-penalized scores:\n","        score_i = global_mean + user_bias + item_bias + u·v  -  alpha * log(e + item_pop)\n","    This prevents the top-k from collapsing to blockbusters.\n","    \"\"\"\n","    print(f\"\\nEvaluating MAP@{k}...\", flush=True)\n","    # FIX: use CustomerID which is retained in test_df\n","    pos = test_df[test_df[\"Rating\"] >= RELEVANCE_THRESH].copy()\n","    if pos.empty:\n","        print(f\"   MAP@{k}: 0.0000  (no positive test examples)\")\n","        return 0.0\n","\n","    user_rel     = pos.groupby(\"CustomerID\")[\"MovieIdx\"].apply(set).to_dict()\n","    user_idx_map = pos.groupby(\"CustomerID\")[\"UserIdx\"].first().to_dict()\n","    candidates   = list(user_rel.keys())\n","\n","    if max_users and len(candidates) > max_users:\n","        rng = np.random.default_rng(RANDOM_SEED)\n","        candidates = rng.choice(candidates, size=max_users, replace=False).tolist()\n","\n","    uf = model.user_factors.cpu().numpy()\n","    if_= model.item_factors.cpu().numpy()\n","    ub = model.user_biases.cpu().numpy()\n","    ib = model.item_biases.cpu().numpy()\n","\n","    # Popularity penalty vector (same for every user)\n","    pop_pen = alpha * item_pop_log                          # shape (n_items,)\n","\n","    ap_list = []\n","    for uid in tqdm(candidates, desc=\"MAP\"):\n","        u_idx   = user_idx_map.get(uid, -1)\n","        rel_set = {mid for mid in user_rel[uid] if mid >= 0}\n","        if not rel_set: continue\n","\n","        if u_idx >= 0:\n","            scores = (model.global_mean + ub[u_idx] + ib\n","                      + uf[u_idx] @ if_.T - pop_pen)\n","        else:\n","            scores = model.global_mean + ib - pop_pen\n","\n","        top_k_idx = np.argsort(-scores)[:k]\n","        hits, prec_sum = 0, 0.0\n","        for rank, iid in enumerate(top_k_idx, 1):\n","            if iid in rel_set:\n","                hits += 1\n","                prec_sum += hits / rank\n","        ap_list.append(prec_sum / min(len(rel_set), k))\n","\n","    map_k = float(np.mean(ap_list)) if ap_list else 0.0\n","    print(f\"   MAP@{k}: {map_k:.4f}  ({len(ap_list):,} users)\")\n","    return map_k\n","\n","# ── 5. MAIN ───────────────────────────────────────────────────────────────────\n","def main():\n","    device = (torch.device(\"cuda\") if torch.cuda.is_available()\n","              else torch.device(\"mps\") if torch.backends.mps.is_available()\n","              else torch.device(\"cpu\"))\n","    print(f\"Using Device: {device}\", flush=True)\n","\n","    candidate_paths = [\n","        \"\",\n","        \"/content/drive/Sharedrives/netflixrecommendationsystem/dataset\",\n","        \"/content/drive/Shareddrives/netflixrecommendationsystem/dataset\",\n","    ]\n","    DATA_DIR = next((p for p in candidate_paths\n","                     if os.path.exists(os.path.join(p, \"train.parquet\"))), \"\")\n","    print(f\"Dataset dir: '{DATA_DIR or '.'}'\", flush=True)\n","\n","    train_df = load_df(os.path.join(DATA_DIR, \"train.parquet\"))\n","    test_df  = load_df(os.path.join(DATA_DIR, \"test.parquet\"))\n","\n","    u_enc, i_enc, u_counts_arr, i_counts_arr = build_encoders_and_frequencies(train_df)\n","    n_users, n_items = len(u_enc), len(i_enc)\n","    print(f\"   {n_users:,} users | {n_items:,} items\")\n","\n","    # Map IDs — keep CustomerID in test_df for MAP eval\n","    print(\"Mapping IDs and calculating weights...\", flush=True)\n","    train_df[\"UserIdx\"]  = train_df[\"CustomerID\"].map(u_enc).astype(np.int32)\n","    train_df[\"MovieIdx\"] = train_df[\"MovieID\"].map(i_enc).astype(np.int32)\n","\n","    u_log_freq = np.log(np.e + u_counts_arr).astype(np.float32)\n","    i_log_freq = np.log(np.e + i_counts_arr).astype(np.float32)\n","    train_df[\"Weight\"] = 1.0 / (u_log_freq[train_df[\"UserIdx\"].values]\n","                                 * i_log_freq[train_df[\"MovieIdx\"].values])\n","\n","    # test_df: keep CustomerID for MAP eval, map indices\n","    test_df[\"UserIdx\"]  = test_df[\"CustomerID\"].map(u_enc).fillna(-1).astype(np.int32)\n","    test_df[\"MovieIdx\"] = test_df[\"MovieID\"].map(i_enc).fillna(-1).astype(np.int32)\n","\n","    # Build flat CSR (by user)\n","    print(\"Building flat CSR (user)...\", flush=True)\n","    u_sort = np.argsort(train_df[\"UserIdx\"].values)\n","    user_items_flat   = train_df[\"MovieIdx\"].values[u_sort].astype(np.int32)\n","    user_ratings_flat = train_df[\"Rating\"].values[u_sort].astype(np.float32)\n","    user_weights_flat = train_df[\"Weight\"].values[u_sort].astype(np.float32)\n","    uc = np.bincount(train_df[\"UserIdx\"].values, minlength=n_users)\n","    user_indptr = np.zeros(n_users + 1, dtype=np.int32);  np.cumsum(uc, out=user_indptr[1:])\n","    del u_sort;  gc.collect()\n","\n","    print(\"Building flat CSC (item)...\", flush=True)\n","    i_sort = np.argsort(train_df[\"MovieIdx\"].values)\n","    item_users_flat   = train_df[\"UserIdx\"].values[i_sort].astype(np.int32)\n","    item_ratings_flat = train_df[\"Rating\"].values[i_sort].astype(np.float32)\n","    item_weights_flat = train_df[\"Weight\"].values[i_sort].astype(np.float32)\n","    ic = np.bincount(train_df[\"MovieIdx\"].values, minlength=n_items)\n","    item_indptr = np.zeros(n_items + 1, dtype=np.int32);  np.cumsum(ic, out=item_indptr[1:])\n","    del i_sort, train_df;  gc.collect()\n","\n","    global_mean = float(user_ratings_flat.mean())\n","    print(f\"   Global mean rating: {global_mean:.4f}\")\n","\n","    # item_pop_log used in MAP penalty\n","    item_pop_log = np.log(np.e + i_counts_arr).astype(np.float32)\n","\n","    wals = PyTorchWALS(n_users, n_items, global_mean, item_pop_log,\n","                       factors=FACTORS, regularization=REGULARIZATION, device=device)\n","\n","    print(f\"\\nTraining WALS [{ITERATIONS} epochs, reg={REGULARIZATION}, F={FACTORS}]...\", flush=True)\n","    best_map, no_improve = 0.0, 0\n","    history = []\n","\n","    for epoch in range(1, ITERATIONS + 1):\n","        t0 = time.time()\n","        wals.train_step(\n","            user_indptr, user_items_flat, user_ratings_flat, user_weights_flat,\n","            item_indptr, item_users_flat, item_ratings_flat, item_weights_flat\n","        )\n","        loss = wals.train_loss(user_indptr, user_items_flat, user_ratings_f