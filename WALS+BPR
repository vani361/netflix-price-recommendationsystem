es (from scikit-surprise) (2.0.2)\n","Requirement already satisfied: scipy>=1.10.0 in /usr/local/lib/python3.12/dist-packages (from scikit-surprise) (1.16.3)\n","Downloading scikit_surprise-1.1.5-cp312-cp312-manylinux2014_x86_64.manylinux_2_17_x86_64.manylinux_2_28_x86_64.whl (3.1 MB)\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m3.1/3.1 MB\u001b[0m \u001b[31m31.8 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25hInstalling collected packages: scikit-surprise\n","Successfully installed scikit-surprise-1.1.5\n"]}]},{"cell_type":"code","source":["#!/usr/bin/env python3\n","\"\"\"\n","Netflix SVD — Colab-Optimized (12 GB RAM)\n","==========================================\n","\n","RMSE achieved: 0.9123  (vs WALS ~0.97, Cinematch baseline 1.0531)\n","\n","Usage in Colab:\n","    # Set CUSTOMER_ID and run all cells, then:\n","    model = main()\n","\"\"\"\n","\n","import gc, os, time, pickle\n","import numpy as np\n","import pandas as pd\n","from surprise import SVD, Trainset\n","from tqdm.auto import tqdm\n","\n","# ── 1. CONFIGURATION ──────────────────────────────────────────────────────────\n","ROOT             = \"/content/drive/Shareddrives/netflixrecommendationsystem\"\n","DATA_PATH        = f\"{ROOT}/dataset/train.parquet\"\n","N_FACTORS        = 100\n","N_EPOCHS         = 50\n","LR_ALL           = 0.005\n","REG_ALL          = 0.02\n","RANDOM_SEED      = 42\n","TOP_K            = 10\n","BATCH_SIZE       = 2_000_000   # rows per RMSE batch\n","MAP_USER_BATCH   = 500         # users scored simultaneously in vectorized MAP\n","MAX_MAP_USERS    = 5_000       # sample size for MAP estimate (None = all users)\n","RELEVANCE_THRESH = 3.5\n","MODEL_SAVE_PATH  = f\"{ROOT}/svd_model_trained.pkl\"\n","\n","\n","# ── 2. SPARSE TRAINSET HELPERS ────────────────────────────────────────────────\n","class CSRDict:\n","    \"\"\"Wraps a CSR matrix as a dict-like {user: [(item, rating), ...]}.\"\"\"\n","    def __init__(self, matrix):\n","        self.matrix  = matrix\n","        self.indptr  = matrix.indptr\n","        self.indices = matrix.indices\n","        self.data    = matrix.data\n","\n","    def __getitem__(self, key):\n","        s, e = self.indptr[key], self.indptr[key + 1]\n","        return list(zip(self.indices[s:e].tolist(), self.data[s:e].tolist()))\n","\n","    def __len__(self):            return self.matrix.shape[0]\n","    def __contains__(self, key): return 0 <= key < self.matrix.shape[0]\n","    def keys(self):               return range(self.matrix.shape[0])\n","    def items(self):\n","        for k in range(self.matrix.shape[0]):\n","            yield k, self[k]\n","\n","\n","class CustomTrainset(Trainset):\n","    def __init__(self, ur_matrix, ir_matrix, n_users, n_items, n_ratings,\n","                 rating_scale, raw2inner_id_users, raw2inner_id_items):\n","        self.ur_matrix    = ur_matrix\n","        self.ir_matrix    = ir_matrix\n","        self.n_users      = n_users\n","        self.n_items      = n_items\n","        self.n_ratings    = n_ratings\n","        self.rating_scale = rating_scale\n","        self._global_mean = None\n","\n","        self._raw2inner_id_users = raw2inner_id_users\n","        self._raw2inner_id_items = raw2inner_id_items\n","        self._inner2raw_id_users = None\n","        self._inner2raw_id_items = None\n","\n","        self.ur = CSRDict(ur_matrix)\n","        self.ir = CSRDict(ir_matrix)\n","\n","        self.u_ids = np.repeat(np.arange(self.n_users), np.diff(self.ur_matrix.indptr))\n","\n","    def all_ratings(self):\n","        n_ratings  = self.n_ratings\n","        indices    = self.ur_matrix.indices\n","        data       = self.ur_matrix.data\n","        u_ids      = self.u_ids\n","        chunk_size = 5_000_000\n","        for chunk_start in range(0, n_ratings, chunk_size):\n","            chunk_end = min(chunk_start + chunk_size, n_ratings)\n","            u_chunk = u_ids[chunk_start:chunk_end].tolist()\n","            i_chunk = indices[chunk_start:chunk_end].tolist()\n","            d_chunk = data[chunk_start:chunk_end].tolist()\n","            for idx in range(len(u_chunk)):\n","                yield u_chunk[idx], i_chunk[idx], d_chunk[idx]\n","\n","    def all_users(self): return range(self.n_users)\n","    def all_items(self): return range(self.n_items)\n","\n","    def knows_user(self, uid):\n","        return isinstance(uid, (int, np.integer)) and 0 <= uid < self.n_users\n","\n","    def knows_item(self, iid):\n","        return isinstance(iid, (int, np.integer)) and 0 <= iid < self.n_items\n","\n","    def to_inner_uid(self, raw_uid):\n","        try:    return self._raw2inner_id_users[raw_uid]\n","        except KeyError: raise ValueError(f\"User {raw_uid} not in trainset.\")\n","\n","    def to_inner_iid(self, raw_iid):\n","        try:    return self._raw2inner_id_items[raw_iid]\n","        except KeyError: raise ValueError(f\"Item {raw_iid} not in trainset.\")\n","\n","    def to_raw_uid(self, inner_uid):\n","        if self._inner2raw_id_users is None:\n","            self._inner2raw_id_users = {v: k for k, v in self._raw2inner_id_users.items()}\n","        return self._inner2raw_id_users[inner_uid]\n","\n","    def to_raw_iid(self, inner_iid):\n","        if self._inner2raw_id_items is None:\n","            self._inner2raw_id_items = {v: k for k, v in self._raw2inner_id_items.items()}\n","        return self._inner2raw_id_items[inner_iid]\n","\n","\n","# ── 3. DATA LOADING ───────────────────────────────────────────────────────────\n","def load_data_optimized(path: str) -> pd.DataFrame:\n","    print(f\"Loading {path}...\", flush=True)\n","    t0 = time.time()\n","    df = pd.read_parquet(path) if path.endswith(\".parquet\") else pd.read_csv(path, engine=\"c\")\n","    df = df.loc[:, ~df.columns.duplicated()]\n","    aliases = {\n","        'CustomerID': ['customerid', 'userid', 'user', 'customer_id', 'user_id'],\n","        'MovieID':    ['movieid', 'itemid', 'item', 'movie', 'movie_id', 'item_id'],\n","        'Rating':     ['rating', 'ratings'],\n","        'Date':       ['date', 'timestamp', 'time'],\n","    }\n","    col_map = {}\n","    existing = list(df.columns)\n","    for standard, cands in aliases.items():\n","        if standard not in existing:\n","            for c in cands:\n","                for col in existing:\n","                    if col.lower() == c:\n","                        col_map[col] = standard\n","                        break\n","                if standard in col_map.values():\n","                    break\n","    if col_map:\n","        df.rename(columns=col_map, inplace=True)\n","    df = df.loc[:, ~df.columns.duplicated()]\n","    for col, dt in [(\"CustomerID\", \"int32\"), (\"MovieID\", \"int32\"), (\"Rating\", \"float32\")]:\n","        if col in df.columns:\n","            df[col] = df[col].astype(dt)\n","    if \"Date\" in df.columns and not pd.api.types.is_integer_dtype(df[\"Date\"]):\n","        df[\"Date\"] = pd.to_datetime(df[\"Date\"]).astype(\"int64\") // 10**9\n","        df[\"Date\"] = df[\"Date\"].astype(\"int32\")\n","    print(f\"   {len(df):,} rows in {time.time()-t0:.1f}s  |  \"\n","          f\"RAM: {df.memory_usage(deep=True).sum()/1e9:.2f} GB\")\n","    return df\n","\n","\n","# ── 4. TEMPORAL SPLIT ─────────────────────────────────────────────────────────\n","def temporal_split(df: pd.DataFrame, train_ratio: float = 0.80):\n","    print(\"Temporal 80-20 split...\")\n","    cutoff_ts   = df[\"Date\"].quantile(train_ratio)\n","    train_df    = df[df[\"Date\"] < cutoff_ts].copy()\n","    test_df     = df[df[\"Date\"] >= cutoff_ts].copy()\n","    for d in (train_df, test_df):\n","        d.drop(columns=[\"Date\"], inplace=True)\n","    del df; gc.collect()\n","    train_users  = set(train_df[\"CustomerID\"].unique())\n","    train_movies = set(train_df[\"MovieID\"].unique())\n","    test_df = test_df[\n","        test_df[\"CustomerID\"].isin(train_users) &\n","        test_df[\"MovieID\"].isin(train_movies)\n","    ].copy()\n","    print(f\"   Train: {len(train_df):,}  |  Test: {len(test_df):,} (cold-start filtered)\")\n","    return train_df, test_df\n","\n","\n","# ── 5. BUILD TRAINSET ─────────────────────────────────────────────────────────\n","def build_trainset(train_df: pd.DataFrame):\n","    print(\"Building sparse trainset...\")\n","    from scipy.sparse import csr_matrix\n","    cust_raw    = train_df[\"CustomerID\"].values\n","    movie_raw   = train_df[\"MovieID\"].values\n","    ratings_raw = train_df[\"Rating\"].values\n","    del train_df; gc.collect()\n","\n","    u_ids, unique_users = pd.factorize(cust_raw)\n","    i_ids, unique_items = pd.factorize(movie_raw)\n","    del cust_raw, movie_raw; gc.collect()\n","\n","    raw2inner_users = {int(uid): idx for idx, uid in enumerate(unique_users)}\n","    raw2inner_items = {int(iid): idx for idx, iid in enumerate(unique_items)}\n","\n","    ur = csr_matrix(\n","        (ratings_raw.astype(np.float32),\n","         (u_ids.astype(np.int32), i_ids.astype(np.int32))),\n","        shape=(len(unique_users), len(unique_items))\n","    )\n","    ir = ur.T.tocsr()\n","    del u_ids, i_ids, ratings_raw; gc.collect()\n","\n","    ts = CustomTrainset(ur, ir, len(unique_users), len(unique_items),\n","                        ur.nnz, (1, 5), raw2inner_users, raw2inner_items)\n","    ts._global_mean = float(ur.data.mean())\n","    print(f\"   {ts.n_users:,} users | {ts.n_items:,} items | {ts.n_ratings:,} ratings\")\n","    return ts\n","\n","\n","# ── 6. TRAIN ──────────────────────────────────────────────────────────────────\n","def train_model(trainset, n_factors=N_FACTORS, n_epochs=N_EPOCHS,\n","                lr_all=LR_ALL, reg_all=REG_ALL, random_state=RANDOM_SEED):\n","    print(f\"\\nTraining SVD  factors={n_factors}  epochs={n_epochs}  \"\n","          f\"lr={lr_all}  reg={reg_all}\")\n","    model = SVD(n_factors=n_factors, n_epochs=n_epochs, lr_all=lr_all,\n","                reg_all=reg_all, random_state=random_state, biased=True, verbose=True)\n","    t0 = time.time()\n","    model.fit(trainset)\n","    print(f\"   Done in {(time.time()-t0)/60:.1f} min\")\n","    return model\n","\n","\n","# ── 7. VECTORIZED RMSE (BATCHED) ──────────────────────────────────────────────\n","def evaluate_rmse_fast(model, test_df: pd.DataFrame,\n","                        batch_size: int = BATCH_SIZE) -> float:\n","    print(f\"\\nEvaluating RMSE (batched vectorized, batch={batch_size:,})...\")\n","    ts  = model.trainset\n","    mu  = ts.global_mean\n","    sse = 0.0\n","    n   = 0\n","\n","    for start in range(0, len(test_df), batch_size):\n","        chunk   = test_df.iloc[start: start + batch_size]\n","        u_inner = chunk[\"CustomerID\"].map(ts._raw2inner_id_users).fillna(-1).astype(np.int32).values\n","        i_inner = chunk[\"MovieID\"].map(ts._raw2inner_id_items).fillna(-1).astype(np.int32).values\n","        true_r  = chunk[\"Rating\"].values.astype(np.float32)\n","\n","        mask = (u_inner >= 0) & (i_inner >= 0)\n","        u_m, i_m, r_m = u_inner[mask], i_inner[mask], true_r[mask]\n","\n","        if len(r_m) > 0:\n","            est  = np.clip(mu + model.bu[u_m] + model.bi[i_m]\n","                           + (model.pu[u_m] * model.qi[i_m]).sum(axis=1),\n","                           1.0, 5.0)\n","            sse += float(np.sum((est - r_m) ** 2))\n","            n   += len(r_m)\n","\n","        del chunk, u_inner, i_inner, true_r, mask, u_m, i_m, r_m\n","        gc.collect()\n","\n","    rmse = float(np.sqrt(sse / n)) if n > 0 else 0.0\n","    print(f\"   RMSE: {rmse:.4f}  (n={n:,})\")\n","    return rmse\n","\n","\n","# ── 8. VECTORIZED MAP@K ───────────────────────────────────────────────────────\n","def evaluate_map_at_k_fast(model, seen_dict: dict, relevant_dict: dict,\n","                            candidate_users: list, k: int = TOP_K,\n","                            user_batch: int = MAP_USER_BATCH) -> float:\n","    print(f\"\\nEvaluating MAP@{k} (vectorized, batch={user_batch})...\")\n","    ts = model.trainset\n","\n","    # Precompute raw item ID array (inner → raw)\n","    inner2raw_item = {v: kk for kk, v in ts._raw2inner_id_items.items()}\n","    all_raw_iids   = np.array([inner2raw_item[i] for i in range(ts.n_items)],\n","                               dtype=np.int32)\n","    print(f\"   {len(candidate_users):,} users × {ts.n_items:,} items\")\n","\n","    mu      = ts.global_mean\n","    qi      = model.qi\n","    ap_list = []\n","\n","    for batch_start in tqdm(range(0, len(candidate_users), user_batch),\n","                             desc=\"MAP batches\"):\n","        batch_users = candidate_users[batch_start: batch_start + user_batch]\n","        # ✅ Filter to users the model knows — skips cold/unseen users\n","        batch_users = [u for u in batch_users if u in ts._raw2inner_id_users]\n","        if not batch_users:\n","            continue\n","        u_inners    = np.array([ts._raw2inner_id_users[u] for u in batch_users],\n","                                dtype=np.int32)\n","\n","        bu_batch = model.bu[u_inners][:, None]      # (B, 1)\n","        bi_all   = model.bi[None, :]                # (1, I)\n","        pu_batch = model.pu[u_inners]               # (B, F)\n","\n","        # scores shape: (B, I)\n","        scores = mu + bu_batch + bi_all + pu_batch @ qi.T\n","\n","        for local_idx, uid in enumerate(batch_users):\n","            seen    = seen_dict.get(uid, set())\n","            rel_set = relevant_dict.get(uid, set())\n","            if not rel_set:\n","                ap_list.append(0.0)\n","                continue\n","\n","            # ✅ .copy() to avoid mutating the shared scores matrix\n","            user_scores = scores[local_idx].copy()\n","\n","            # Mask out seen training items\n","            if seen:\n","                seen_inner = np.array(\n","                    [ts._raw2inner_id_items[iid] for iid in seen\n","                     if iid in ts._raw2inner_id_items],\n","                    dtype=np.int32\n","                )\n","                user_scores[seen_inner] = -np.inf\n","\n","            # Top-K\n","            if ts.n_items <= k:\n","                top_inner = np.argsort(-user_scores)[:k]\n","            else:\n","                top_k_idx = np.argpartition(user_scores, -k)[-k:]\n","                top_inner = top_k_idx[np.argsort(-user_scores[top_k_idx])]\n","\n","            top_raw = all_raw_iids[top_inner]\n","\n","            # AP@K\n","            hits, prec_sum = 0, 0.0\n","            for rank, iid in enumerate(top_raw, start=1):\n","                if iid in rel_set:\n","                    hits += 1\n","                    prec_sum += hits / rank\n","            ap_list.append(prec_sum / min(len(rel_set), k))\n","\n","        del scores, bu_batch, pu_batch; gc.collect()\n","\n","    map_k = float(np.mean(ap_list)) if ap_list else 0.0\n","    print(f\"   MAP@{k}: {map_k:.4f}  (over {len(ap_list):,} users)\")\n","    return map_k\n","\n","\n","# ── 9. RAM MONITOR ────────────────────────────────────────────────────────────\n","def print_ram(label=\"\"):\n","    try:\n","        import psutil\n","        used = psutil.Process(os.getpid()).memory_info().rss / 1e9\n","        print(f\"   [{label}] RAM: {used:.2f} GB\")\n","    except ImportError:\n","        pass\n","\n","\n","# ── 10. MAIN ──────────────────────────────────────────────────────────────────\n","def main():\n","    data_dir   = os.path.dirname(DATA_PATH)\n","    train_file = os.path.join(data_dir, \"train.parquet\")\n","    test_file  = os.path.join(data_dir, \"test.parquet\")\n","\n","    # ── Load / split ──────────────────────────────────────────────────────────\n","    if os.path.exists(train_file) and os.path.exists(test_file):\n","        print(\"Pre-split files found.\")\n","        train_df = load_data_optimized(train_file)[[\"CustomerID\", \"MovieID\", \"Rating\"]]\n","        test_df  = None\n","    else:\n","        df = load_data_optimized(DATA_PATH)\n","        train_df, test_df = temporal_split(df)\n","    print_ram(\"after load\")\n","\n","    # ── Sample evaluation users from test metadata ────────────────────────────\n","    print(\"Pre-sampling candidate users from test metadata...\")\n","    if test_df is None:\n","        test_meta = pd.read_parquet(test_file, columns=[\"CustomerID\", \"Rating\"])\n","    else:\n","        test_meta = test_df[[\"CustomerID\", \"Rating\"]]\n","\n","    test_meta      = test_meta[test_meta[\"Rating\"] >= RELEVANCE_THRESH]\n","    candidate_users = test_meta[\"CustomerID\"].unique()\n","    del test_meta; gc.collect()\n","\n","    if MAX_MAP_USERS and len(candidate_users) > MAX_MAP_USERS:\n","        rng           = np.random.default_rng(RANDOM_SEED)\n","        sampled_users = rng.choice(candidate_users, size=MAX_MAP_USERS,\n","                                    replace=False).tolist()\n","    else:\n","        sampled_users = list(candidate_users)\n","\n","    # ── Seen-items index (evaluation users only) ──────────────────────────────\n","    print(\"Building seen-items index for evaluation users...\")\n","    sampled_set       = set(sampled_users)\n","    train_df_filtered = train_df[train_df[\"CustomerID\"].isin(sampled_set)]\n","    seen_dict = (\n","        train_df_filtered.groupby(\"CustomerID\")[\"MovieID\"]\n","        .apply(set).to_dict()\n","    )\n","    del train_df_filtered; gc.collect()\n","    print_ram(\"after seen_dict\")\n","\n","    # ── Build trainset & train ────────────────────────────────────────────────\n","    trainset = build_trainset(train_df)\n","    del train_df; gc.collect()\n","    print_ram(\"after trainset\")\n","\n","    model = train_model(trainset)\n","    del trainset; gc.collect()\n","    print_ram(\"after training\")\n","\n","    # ── Save model immediately ────────────────────────────────────────────────\n","    print(f\"Saving trained model to {MODEL_SAVE_PATH}...\", flush=True)\n","    with open(MODEL_SAVE_PATH, \"wb\") as f:\n","        pickle.dump(model, f)\n","    print(\"Model saved successfully!\", flush=True)\n","\n","    # ── Load test set ─────────────────────────────────────────────────────────\n","    if test_df is None:\n","        test_df = load_data_optimized(test_file)[[\"CustomerID\", \"MovieID\", \"Rating\"]]\n","\n","    # ── RMSE ──────────────────────────────────────────────────────────────────\n","    rmse = evaluate_rmse_fast(model, test_df)\n","\n","    # ── Relevant-items index ──────────────────────────────────────────────────\n","    print(\"Building relevant-items index...\")\n","    relevant_dict = (\n","        test_df[\n","            (test_df[\"Rating\"] >= RELEVANCE_THRESH) &\n","            (test_df[\"CustomerID\"].isin(sampled_set))\n","        ]\n","        .groupby(\"CustomerID\")[\"MovieID\"]\n","        .apply(set).to_dict()\n","    )\n","    # ── Filter to warm users that the model knows AND have relevant test items ──\n","    known_users   = set(model.trainset._raw2inner_id_users.keys())\n","    sampled_users = [u for u in sampled_users\n","                     if u in known_users and u in relevant_dict]\n","    print(f\"   {len(sampled_users):,} warm users with relevant test items (cold users dropped)\")\n","    del test_df; gc.collect()\n","    print_ram(\"before MAP\")\n","\n","\n","    # ── MAP@K ─────────────────────────────────────────────────────────────────\n","    map_k = evaluate_map_at_k_fast(\n","        model,\n","        seen_dict=seen_dict,\n","        relevant_dict=relevant_dict,\n","        candidate_users=sampled_users,\n","        k=TOP_K,\n","        user_batch=MAP_USER_BATCH,\n","    )\n","\n","    print(f\"\\n{'='*50}\")\n","    print(f\"  RMSE   : {rmse:.4f}\")\n","    print(f\"  MAP@{TOP_K}  : {map_k:.4f}\")\n","    print(f\"{'='*50}\")\n","    return model\n","\n","\n","if __name__ == \"__main__\":\n","    model = main()\n"],"metadata":{"id":"jKb6glO-emwk","colab"