ases.\n","Uses frequency-based sample weights to penalize blockbuster dominance,\n","boosting personalized ranking accuracy (MAP@10) while remaining memory-safe.\n","Optimized for 12GB RAM system limits using flat CSR/CSC array representations.\n","\n","FIX: Sample weights are normalized to mean=1.0 so that REG_BIAS / REGULARIZATION\n","act consistently across high- and low-frequency users/items. Without this,\n","the previous REG_BIAS=15.0 dominated the weighted denominator for popular\n","entities (whose weights were heavily downweighted), causing RMSE to diverge\n","monotonically after epoch 1-2.\n","\"\"\"\n","\n","import gc\n","import os\n","import time\n","import pickle\n","import numpy as np\n","import pandas as pd\n","import torch\n","from tqdm.auto import tqdm\n","\n","# ── CONFIG ────────────────────────────────────────────────────────────────────\n","FACTORS          = 32          # even smaller — 64 may still be too expressive\n","REGULARIZATION   = 8.0         # much stronger\n","REG_BIAS         = 5.0         # also stronger\n","ITERATIONS       = 20\n","RELEVANCE_THRESH = 3.5\n","TOP_K            = 10\n","MAX_MAP_USERS    = 5_000\n","RANDOM_SEED      = 42\n","BATCH_SIZE       = 1024\n","\n","# ── 1. LOAD DATA ──────────────────────────────────────────────────────────────\n","def load_df(path):\n","    print(f\"Loading {path}...\", flush=True)\n","    t0 = time.time()\n","\n","    if path.endswith(\".parquet\"):\n","        import pyarrow.parquet as pq\n","        file_cols = pq.ParquetFile(path).schema.names\n","    else:\n","        file_cols = list(pd.read_csv(path, nrows=1).columns)\n","\n","    col_map = {}\n","    for col in file_cols:\n","        cl = col.lower()\n","        if cl in (\"customerid\", \"userid\", \"user_id\", \"customer_id\"): col_map[\"CustomerID\"] = col\n","        elif cl in (\"movieid\", \"itemid\", \"movie_id\", \"item_id\"):      col_map[\"MovieID\"] = col\n","        elif cl in (\"rating\", \"ratings\"):                           col_map[\"Rating\"] = col\n","\n","    load_cols = [col_map[k] for k in [\"CustomerID\", \"MovieID\", \"Rating\"] if k in col_map]\n","\n","    df = pd.read_parquet(path, columns=load_cols) if path.endswith(\".parquet\") else pd.read_csv(path, usecols=load_cols)\n","\n","    rename = {v: k for k, v in col_map.items()}\n","    df.rename(columns=rename, inplace=True)\n","    df = df.loc[:, ~df.columns.duplicated()]\n","\n","    df[\"CustomerID\"] = df[\"CustomerID\"].astype(\"int32\")\n","    df[\"MovieID\"]    = df[\"MovieID\"].astype(\"int32\")\n","    df[\"Rating\"]     = df[\"Rating\"].astype(\"float32\")\n","    print(f\"   {len(df):,} rows loaded in {time.time()-t0:.1f}s\")\n","    return df\n","\n","# ── 2. ENCODERS & FREQUENCIES ─────────────────────────────────────────────────\n","def build_encoders_and_frequencies(train_df):\n","    user_counts = train_df[\"CustomerID\"].value_counts(ascending=True)\n","    sorted_users = user_counts.index.values\n","    u_counts_arr = user_counts.values.astype(np.float32)\n","\n","    item_counts = train_df[\"MovieID\"].value_counts(ascending=True)\n","    sorted_items = item_counts.index.values\n","    i_counts_arr = item_counts.values.astype(np.float32)\n","\n","    u_enc = {u: i for i, u in enumerate(sorted_users)}\n","    i_enc = {v: i for i, v in enumerate(sorted_items)}\n","    return u_enc, i_enc, u_counts_arr, i_counts_arr\n","\n","# ── 3. PYTORCH WALS SOLVER ────────────────────────────────────────────────────\n","class PyTorchWALS:\n","    def __init__(self, n_users, n_items, global_mean, factors=FACTORS, regularization=REGULARIZATION, reg_bias=REG_BIAS, device=\"cpu\"):\n","        self.n_users = n_users\n","        self.n_items = n_items\n","        self.global_mean = global_mean\n","        self.factors = factors\n","        self.reg = regularization\n","        self.reg_bias = reg_bias\n","        self.device = device\n","\n","        generator = torch.Generator().manual_seed(RANDOM_SEED)\n","        self.user_factors = torch.randn(n_users, factors, generator=generator, device=\"cpu\").to(device) * 0.01\n","        self.item_factors = torch.randn(n_items, factors, generator=generator, device=\"cpu\").to(device) * 0.01\n","        self.user_biases = torch.zeros(n_users, device=device)\n","        self.item_biases = torch.zeros(n_items, device=device)\n","\n","    def train_step(self, user_indptr, user_items_flat, user_ratings_flat, user_weights_flat,\n","                   item_indptr, item_users_flat, item_ratings_flat, item_weights_flat):\n","        self.user_factors, self.user_biases = self._solve_factors(\n","            self.user_factors, self.item_factors, self.user_biases, self.item_biases,\n","            user_indptr, user_items_flat, user_ratings_flat, user_weights_flat, update_type=\"Users\"\n","        )\n","\n","        self.item_factors, self.item_biases = self._solve_factors(\n","            self.item_factors, self.user_factors, self.item_biases, self.user_biases,\n","            item_indptr, item_users_flat, item_ratings_flat, item_weights_flat, update_type=\"Items\"\n","        )\n","\n","    def _solve_factors(self, X, Y, biases_X, biases_Y, indptr, items_flat, ratings_flat, weights_flat, update_type=\"user\"):\n","        n_entities = X.shape[0]\n","        new_X = torch.zeros_like(X)\n","        new_biases = torch.zeros_like(biases_X)\n","        I = torch.eye(self.factors, device=self.device)\n","\n","        start = 0\n","        pbar = tqdm(total=n_entities, desc=f\"Solving {update_type}\", leave=False)\n","        while start < n_entities:\n","            candidate_size = 256\n","            candidate_end = min(start + candidate_size, n_entities)\n","\n","            lens = indptr[start+1 : candidate_end+1] - indptr[start : candidate_end]\n","            local_max_len = int(lens.max()) if len(lens) > 0 else 0\n","\n","            if local_max_len > 0:\n","                safe_batch_size = max(1, 100_000_000 // (local_max_len * self.factors))\n","                batch_size = min(candidate_size, safe_batch_size)\n","            else:\n","                batch_size = candidate_size\n","\n","            end = min(start + batch_size, n_entities)\n","            ents_t = torch.arange(start, end, device=self.device)\n","\n","            batch_lens = indptr[start+1 : end+1] - indptr[start : end]\n","            max_len = int(batch_lens.max()) if len(batch_lens) > 0 else 0\n","            if max_len == 0:\n","                new_X[start:end] = 0.0\n","                new_biases[start:end] = 0.0\n","                start = end\n","                pbar.update(batch_size)\n","                continue\n","\n","            padded_items = np.zeros((end - start, max_len), dtype=np.int64)\n","            padded_ratings = np.zeros((end - start, max_len), dtype=np.float32)\n","            padded_weights = np.zeros((end - start, max_len), dtype=np.float32)\n","\n","            for idx, u in enumerate(range(start, end)):\n","                s_ptr = indptr[u]\n","                e_ptr = indptr[u+1]\n","                l = e_ptr - s_ptr\n","                if l > 0:\n","                    padded_items[idx, :l] = items_flat[s_ptr : e_ptr]\n","                    padded_ratings[idx, :l] = ratings_flat[s_ptr : e_ptr]\n","                    padded_weights[idx, :l] = weights_flat[s_ptr : e_ptr]\n","\n","            t_items = torch.from_numpy(padded_items).to(self.device)\n","            t_ratings = torch.from_numpy(padded_ratings).to(self.device)\n","            t_weights = torch.from_numpy(padded_weights).to(self.device)\n","\n","            V = Y[t_items]\n","            b_Y_batch = biases_Y[t_items]\n","\n","            # --- 1. Update Biases (Weighted) ---\n","            X_batch = X[ents_t]\n","            dot_products = (X_batch.unsqueeze(1) * V).sum(dim=2)\n","\n","            sum_term = ((t_ratings - self.global_mean - b_Y_batch - dot_products) * t_weights).sum(dim=1)\n","            b_new = sum_term / (t_weights.sum(dim=1) + self.reg_bias)\n","            new_biases[ents_t] = b_new\n","\n","            # --- 2. Update Latent Factors (Weighted) ---\n","            residuals = (t_ratings - self.global_mean - b_new.unsqueeze(1) - b_Y_batch) * t_weights\n","            V_weighted = V * t_weights.unsqueeze(-1)\n","\n","            A = V.transpose(1, 2) @ V_weighted + self.reg * I.unsqueeze(0)\n","            b_vec = (V * residuals.unsqueeze(-1)).sum(dim=1)\n","\n","            L = torch.linalg.cholesky(A)\n","            x_new = torch.cholesky_solve(b_vec.unsqueeze(-1), L).squeeze(-1)\n","            new_X[ents_t] = x_new\n","\n","            start = end\n","            pbar.update(batch_size)\n","\n","        pbar.close()\n","        return new_X, new_biases\n","\n","# ── 4. EVALUATIONS ────────────────────────────────────────────────────────────\n","def evaluate_rmse(model, df, chunk=100_000, desc=\"RMSE\", max_samples=1_000_000):\n","    print(f\"\\nEvaluating {desc} (sampled to {max_samples:,} rows)...\" if max_samples and len(df) > max_samples else f\"\\nEvaluating {desc} (all rows)...\", flush=True)\n","\n","    if max_samples and len(df) > max_samples:\n","        df = df.sample(n=max_samples, random_state=42)\n","\n","    user_factors = model.user_factors.cpu().numpy()\n","    item_factors = model.item_factors.cpu().numpy()\n","    user_biases = model.user_biases.cpu().numpy()\n","    item_biases = model.item_biases.cpu().numpy()\n","\n","    sse, n = 0.0, 0\n","    for start in tqdm(range(0, len(df), chunk), desc=desc, leave=False):\n","        end = start + chunk\n","        # Use .iloc because sampling scrambles the index\n","        u_idx = df[\"UserIdx\"].iloc[start:end].values\n","        i_idx = df[\"MovieIdx\"].iloc[start:end].values\n","        true_r = df[\"Rating\"].iloc[start:end].values\n","\n","        est = np.full(len(u_idx), model.global_mean, dtype=np.float32)\n","\n","        user_is_warm = u_idx >= 0\n","        item_is_warm = i_idx >= 0\n","        both_warm = user_is_warm & item_is_warm\n","\n","        if user_is_warm.any():\n","            est[user_is_warm] += user_biases[u_idx[user_is_warm]]\n","\n","        if item_is_warm.any():\n","            est[item_is_warm] += item_biases[i_idx[item_is_warm]]\n","\n","        if both_warm.any():\n","            est[both_warm] += (user_factors[u_idx[both_warm]] * item_factors[i_idx[both_warm]]).sum(axis=1)\n","\n","        est = np.clip(est, 1.0, 5.0)\n","        sse += np.sum((est - true_r) ** 2)\n","        n += len(true_r)\n","\n","        del u_idx, i_idx, true_r, user_is_warm, item_is_warm, both_warm, est\n","        gc.collect()\n","\n","    rmse = (sse / n) ** 0.5 if n > 0 else 0.0\n","    print(f\"   RMSE: {rmse:.4f}  (n={n:,})\")\n","    return rmse\n","\n","def evaluate_map_at_k(model, test_df, k=TOP_K, max_users=MAX_MAP_USERS):\n","    print(f\"\\nEvaluating MAP@{k} (all test rows)...\", flush=True)\n","    pos = test_df[test_df[\"Rating\"] >= RELEVANCE_THRESH].copy()\n","\n","    if pos.empty:\n","        print(f\"   MAP@{k}: 0.0000 (No test cases matched criteria)\")\n","        return 0.0\n","\n","    user_rel = pos.groupby(\"CustomerID\")[\"MovieIdx\"].apply(set).to_dict()\n","    candidate_users = list(user_rel.keys())\n","    user_idx_map = pos.groupby(\"CustomerID\")[\"UserIdx\"].first().to_dict()\n","\n","    if max_users and len(candidate_users) > max_users:\n","        rng = np.random.default_rng(RANDOM_SEED)\n","        candidate_users = rng.choice(candidate_users, size=max_users, replace=False).tolist()\n","\n","    user_factors = model.user_factors.cpu().numpy()\n","    item_factors = model.item_factors.cpu().numpy()\n","    user_biases = model.user_biases.cpu().numpy()\n","    item_biases = model.item_biases.cpu().numpy()\n","\n","    ap_list = []\n","    for uid in tqdm(candidate_users, desc=\"MAP\"):\n","        u_idx = user_idx_map.get(uid, -1)\n","        rel_set = {mid for mid in user_rel[uid] if mid >= 0}\n","        if not rel_set:\n","            continue\n","\n","        if u_idx >= 0:\n","            scores = model.global_mean + user_biases[u_idx] + item_biases + user_factors[u_idx] @ item_factors.T\n","        else:\n","            scores = model.global_mean + item_biases\n","\n","        top_k_idx = np.argsort(-scores)[:k]\n","\n","        hits, precision_sum = 0, 0.0\n","        for rank, inner_iid in enumerate(top_k_idx, start=1):\n","            if inner_iid in rel_set:\n","                hits += 1\n","                precision_sum += hits / rank\n","\n","        ap_list.append(precision_sum / min(len(rel_set), k))\n","\n","    map_k = float(np.mean(ap_list)) if ap_list else 0.0\n","    print(f\"   MAP@{k}: {map_k:.4f}  ({len(ap_list):,} users)\")\n","    return map_k\n","\n","# ── 5. MAIN ───────────────────────────────────────────────────────────────────\n","def main():\n","    if torch.cuda.is_available():\n","        device = torch.device(\"cuda\")\n","    elif torch.backends.mps.is_available():\n","        device = torch.device(\"mps\")\n","    else:\n","        device = torch.device(\"cpu\")\n","    print(f\"Using Device: {device}\", flush=True)\n","\n","    candidate_paths = [\n","        \"\",\n","        \"/content/drive/Sharedrives/netflixrecommendationsystem/dataset\",\n","        \"/content/drive/Shareddrives/netflixrecommendationsystem/dataset\"\n","    ]\n","    DATA_DIR = \"\"\n","    for path in candidate_paths:\n","        if os.path.exists(os.path.join(path, \"train.parquet\")):\n","            DATA_DIR = path\n","            print(f\"Detected dataset directory: '{DATA_DIR if DATA_DIR else '.'}'\", flush=True)\n","            break\n","\n","    train_path = os.path.join(DATA_DIR, \"train.parquet\")\n","    test_path  = os.path.join(DATA_DIR, \"test.parquet\")\n","\n","    train_df = load_df(train_path)\n","    test_df  = load_df(test_path)\n","\n","    u_enc, i_enc, u_counts_arr, i_counts_arr = build_encoders_and_frequencies(train_df)\n","    n_users, n_items = len(u_enc), len(i_enc)\n","    print(f\"   {n_users:,} users | {n_items:,} items\")\n","\n","    print(\"Mapping IDs and calculating weights...\", flush=True)\n","    train_df[\"UserIdx\"] = train_df[\"CustomerID\"].map(u_enc).astype(np.int32)\n","    train_df[\"MovieIdx\"] = train_df[\"MovieID\"].map(i_enc).astype(np.int32)\n","\n","    # Calculate sample weights: 1.0 / (log(e + user_count) * log(e + item_count))\n","    u_log_freq = np.log(np.e + u_counts_arr).astype(np.float32)\n","    i_log_freq = np.log(np.e + i_counts_arr).astype(np.float32)\n","    raw_weights = 1.0 / (u_log_freq[train_df[\"UserIdx\"].values] * i_log_freq[train_df[\"MovieIdx\"].values])\n","    weights = raw_weights ** 0.5  # Beta = 0.5\n","\n","    # FIX: normalize weights to mean=1.0 so REG_BIAS / REGULARIZATION act\n","    # consistently regardless of frequency-based downweighting. Without this,\n","    # tw.sum() shrinks drastically for popular users/items, letting REG_BIAS\n","    # dominate their bias updates while sparse entities remain under-regularized\n","    # -> compounding divergence across epochs.\n","    weights = weights / weights.mean()\n","    train_df[\"Weight\"] = weights.astype(np.float32)\n","\n","    train_df = train_df[[\"UserIdx\", \"MovieIdx\", \"Rating\", \"Weight\"]]\n","    gc.collect()\n","\n","    test_df[\"UserIdx\"] = test_df[\"CustomerID\"].map(u_enc).fillna(-1).astype(np.int32)\n","    test_df[\"MovieIdx\"] = test_df[\"MovieID\"].map(i_enc).fillna(-1).astype(np.int32)\n","\n","    print(f\"Cold test users: {(test_df['UserIdx']==-1).mean():.2%}\")\n","    print(f\"Cold test items: {(test_df['MovieIdx']==-1).mean():.2%}\")\n","\n","    print(\"Constructing flat CSR arrays for user ratings...\", flush=True)\n","    user_sort_idx = np.argsort(train_df[\"UserIdx\"].values)\n","    user_items_flat = train_df[\"MovieIdx\"].values[user_sort_idx].astype(np.int32)\n","    user_ratings_flat = train_df[\"Rating\"].values[user_sort_idx].astype(np.float32)\n","    user_weights_flat = train_df[\"Weight\"].values[user_sort_idx].astype(np.float32)\n","\n","    user_counts = np.bincount(train_df[\"UserIdx\"].values, minlength=n_users)\n","    user_indptr = np.zeros(n_users + 1, dtype=np.int32)\n","    np.cumsum(user_counts, out=user_indptr[1:])\n","    del user_sort_idx; gc.collect()\n","\n","    print(\"Constructing flat CSC arrays for item ratings...\", flush=True)\n","    item_sort_idx = np.argsort(train_df[\"MovieIdx\"].values)\n","    item_users_flat = train_df[\"UserIdx\"].values[item_sort_idx].astype(np.int32)\n","    item_ratings_flat = train_df[\"Rating\"].values[item_sort_idx].astype(np.float32)\n","    item_weights_flat = train_df[\"Weight\"].values[item_sort_idx].astype(np.float32)\n","\n","    item_counts = np.bincount(train_df[\"MovieIdx\"].values, minlength=n_items)\n","    item_indptr = np.zeros(n_items + 1, dtype=np.int32)\n","    np.cumsum(item_counts, out=item_indptr[1:])\n","    del item_sort_idx; gc.collect()\n","\n","    global_mean = float(user_ratings_flat.mean())\n","\n","    wals = PyTorchWALS(n_users, n_items, global_mean, factors=FACTORS, regularization=REGULARIZATION, reg_bias=REG_BIAS, device=device)\n","\n","    print(f\"\\nTraining PyTorch WALS on {device}...\", flush=True)\n","    best_test_rmse, best_state = float(\"inf\"), {\n","        \"user_factors\": wals.user_factors.cpu().numpy(),\n","        \"item_factors\": wals.item_factors.cpu().numpy(),\n","        \"user_biases\": wals.user_biases.cpu().numpy(),\n","        \"item_biases\": wals.item_biases.cpu().numpy(),\n","    }\n","    for epoch in range(1, ITERATIONS + 1):\n","        t_start = time.time()\n","        wals.train_step(\n","            user_indptr, user_items_flat, user_ratings_flat, user_weights_flat,\n","            item_indptr, item_users_flat, item_ratings_flat, item_weights_flat\n","        )\n","\n","        # Evaluate on sample at each step\n","        train_rmse = evaluate_rmse(wals, train_df, desc=\"Train RMSE\")\n","        test_rmse  = evaluate_rmse(wals, test_df, desc=\"Test RMSE\")\n","        print(f\"   Epoch {epoch:2d}/{ITERATIONS} finished in {time.time()-t_start:.1f}s | Train RMSE: {train_rmse:.4f} | Test RMSE: {test_rmse:.4f}\")\n","\n","        if test_rmse < best_test_rmse:\n","            best_test_rmse = test_rmse\n","            best_state = {\n","                \"user_factors\": wals.user_factors.cpu().numpy(),\n","                \"item_factors\": wals.item_factors.cpu().numpy(),\n","                \"user_biases\": wals.user_biases.cpu().numpy(),\n","                \"item_biases\": wals.item_biases.cpu().numpy(),\n","            }\n","            print(f\"    * New best Test RMSE={best_test_rmse:.4f}\")\n","        gc.collect()\n","\n","    print(f\"\\n  Final best Test RMSE (sampled) = {best_test_rmse:.4f}\")\n","\n","    wals.user_factors = torch.from_numpy(best_state[\"user_factors\"]).to(device)\n","    wals.item_factors = torch.from_numpy(best_state[\"item_factors\"]).to(device)\n","    wals.user_biases = torch.from_numpy(best_state[\"user_biases\"]).to(device)\n","    wals.item_biases = torch.from_numpy(best_state[\"item_biases\"]).to(device)\n","\n","    final_train_rmse = evaluate_rmse(wals, train_df, desc=\"Full Train RMSE\", max_samples=None)\n","    final_test_rmse = evaluate_rmse(wals, test_df, desc=\"Full Test RMSE\", max_samples=None)\n","    map_k = evaluate_map_at_k(wals, test_df)\n","\n","    # Split Warm vs. Cold diagnostics\n","    print(\"\\nEvaluating Split Metrics (Warm vs. Cold Test Users)...\", flush=True)\n","    test_warm_df = test_df[test_df[\"UserIdx\"] >= 0]\n","    test_cold_df = test_df[test_df[\"UserIdx\"] < 0]\n","\n","    test_rmse_warm = evaluate_rmse(wals, test_warm_df, desc=\"Warm Test RMSE\", max_samples=None)\n","    test_rmse_cold = evaluate_rmse(wals, test_cold_df, desc=\"Cold Test RMSE\", max_samples=None)\n","\n","    map_k_warm = evaluate_map_at_k(wals, test_warm_df)\n","    map_k_cold = evaluate_map_at_k(wals, test_cold_df)\n","\n","    